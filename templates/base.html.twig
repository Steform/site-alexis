<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr')|slice(0, 2) }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Carrosserie Lino - Baldersheim{% endblock %}</title>
        <link rel="icon" type="image/svg+xml" href="{{ asset('images/favicon-carosserie-lino.svg') }}">
         <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        <script>
            (function(){var s=localStorage.getItem('theme');var d=window.matchMedia('(prefers-color-scheme: dark)').matches;document.documentElement.setAttribute('data-theme',s||(d?'dark':'light'));})();
        </script>
        {{ importmap('app') }}
        {% block head_hreflang %}{% endblock %}
        {% block stylesheets %}{% endblock %}
    </head>
    <body class="d-flex flex-column min-vh-100">
        <div class="flex-grow-1 d-flex flex-column">
            {% block body %}{% endblock %}
        </div>
        <button type="button" class="btn btn-darkmode position-fixed bottom-0 end-0 m-3 shadow" id="btn-darkmode" aria-label="Passer en mode sombre" title="Passer en mode sombre" style="z-index: 1000;">🌙</button>
        {% block javascripts %}{% endblock %}
        <script>
            (function(){if(window.__darkModeInit)return;window.__darkModeInit=1;function updateBtn(){var btn=document.getElementById('btn-darkmode');if(!btn)return;var t=document.documentElement.getAttribute('data-theme');btn.textContent=t==='dark'?'☀️':'🌙';btn.setAttribute('aria-label',t==='dark'?'Passer en mode clair':'Passer en mode sombre');btn.setAttribute('title',t==='dark'?'Passer en mode clair':'Passer en mode sombre');}function initTheme(){updateBtn();}document.addEventListener('DOMContentLoaded',initTheme);document.addEventListener('turbo:load',initTheme);document.addEventListener('click',function(e){var btn=e.target.closest('#btn-darkmode');if(btn){var n=document.documentElement.getAttribute('data-theme')==='dark'?'light':'dark';document.documentElement.setAttribute('data-theme',n);localStorage.setItem('theme',n);updateBtn();}});})();
        </script>
    </body>
</html>
