<footer class="footer-bottom py-3">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-md-3 text-start">
                <p class="mb-0 footer-badge d-flex align-items-center gap-2">
                    <img src="{{ asset('images/logo/assurance-et-expertise.svg') }}" alt="" class="footer-badge-icon" width="18" height="18">
                    {{ 'home.footer.badge1'|trans }}
                </p>
            </div>
            <div class="col-md-3 text-center">
                <p class="mb-0 footer-badge d-inline-flex align-items-center gap-2">
                    <img src="{{ asset('images/logo/vehicule-toute-marque.svg') }}" alt="" class="footer-badge-icon" width="18" height="18">
                    {{ 'home.footer.badge2'|trans }}
                </p>
            </div>
            <div class="col-md-3 text-center">
                <p class="mb-0 footer-badge d-inline-flex align-items-center gap-2">
                    <img src="{{ asset('images/logo/véhicule-de-courtoisie.svg') }}" alt="" class="footer-badge-icon" width="18" height="18">
                    {{ 'home.footer.badge3'|trans }}
                </p>
            </div>
            <div class="col-md-3 text-end">
                <div class="d-flex justify-content-center justify-content-md-end align-items-center gap-3">
                    {% if coordinates is defined and coordinates and coordinates.facebookUrl is not empty %}
                        <a href="{{ coordinates.facebookUrl }}" aria-label="Facebook" title="Facebook" class="d-inline-flex align-items-center" target="_blank" rel="noopener noreferrer">
                            <img src="{{ asset('images/rs/facebook-fav.svg') }}" alt="Facebook" class="footer-social-icon" width="18" height="18">
                        </a>
                    {% endif %}
                    {% if coordinates is defined and coordinates and coordinates.instagramUrl is not empty %}
                        <a href="{{ coordinates.instagramUrl }}" aria-label="Instagram" title="Instagram" class="d-inline-flex align-items-center" target="_blank" rel="noopener noreferrer">
                            <img src="{{ asset('images/rs/instagram-fav.svg') }}" alt="Instagram" class="footer-social-icon" width="18" height="18">
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
        <hr class="w-80 mx-auto">


        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 text-start">
            <span class="footer-meta">
                © {{ 'now'|date('Y') }} Carrosserie Lino
                -
                {% if coordinates is defined and coordinates and coordinates.city is not empty %}
                    {{ coordinates.city }}
                {% else %}
                    {{ 'nav.city'|trans }}
                {% endif %}
                |
                <a href="{{ path_locale('app_mentions_legales') }}" class="text-decoration-none">{{ 'home.footer.legal'|trans }}</a>
                |
                <a href="{{ path_locale('app_contact') }}" class="text-decoration-none">{{ 'home.footer.contact'|trans }}</a>
            </span>
            <div class="footer-meta text-md-end">
                <a href="https://www.stephane-hirt.fr/" class="text-decoration-none" target="_blank" rel="noopener noreferrer">
                    Site créé par HIRT Stéphane
                </a>
            </div>
        </div>
    </div>
</footer>

