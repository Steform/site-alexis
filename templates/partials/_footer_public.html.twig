<footer class="footer-top py-4">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <p class="mb-0">🛡️ {{ 'home.footer.badge1'|trans }}</p>
            </div>
            <div class="col-md-4">
                <p class="mb-0">🚗 {{ 'home.footer.badge2'|trans }}</p>
            </div>
            <div class="col-md-4">
                <p class="mb-0">🔑 {{ 'home.footer.badge3'|trans }}</p>
            </div>
        </div>
    </div>
</footer>
<footer class="footer-bottom py-3">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
            <span>
                © {{ 'now'|date('Y') }} Carrosserie Lino
                -
                {% if coordinates is defined and coordinates and coordinates.city is not empty %}
                    {{ coordinates.city }}
                {% else %}
                    {{ 'nav.city'|trans }}
                {% endif %}
                |
                <a href="{{ path('app_mentions_legales') }}" class="text-decoration-none">{{ 'home.footer.legal'|trans }}</a>
                |
                <a href="{{ path('app_contact') }}" class="text-decoration-none">{{ 'home.footer.contact'|trans }}</a>
            </span>
            <div>
                <a href="#" class="me-3" aria-label="Facebook">f</a>
                <a href="#" aria-label="Instagram">📷</a>
            </div>
        </div>
    </div>
</footer>

