<nav class="navbar navbar-expand-lg navbar-main py-3">
    <div class="container">
        <a class="navbar-brand" href="{{ path_locale('app_home') }}">
            <img src="{{ asset('images/logo-carrosserie-lino.svg') }}" alt="Carrosserie Lino" height="60" class="navbar-logo navbar-logo-light">
            <img src="{{ asset('images/logo-carrosserie-lino-dark.svg') }}" alt="Carrosserie Lino" height="60" class="navbar-logo navbar-logo-dark">
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain" aria-controls="navMain" aria-expanded="false" aria-label="Menu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMain">
            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item">
                    <a class="nav-link {{ app.request.attributes.get('_route') in ['app_home', 'app_home_de'] ? 'active' : '' }}" href="{{ path_locale('app_home') }}">
                        {{ 'nav.home'|trans }}
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ app.request.attributes.get('_route') in ['app_services', 'app_services_show', 'app_services_de', 'app_services_show_de'] ? 'active' : '' }}" href="{{ path_locale('app_services') }}">
                        {{ 'nav.services'|trans }}
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ app.request.attributes.get('_route') in ['app_gallery', 'app_gallery_de'] ? 'active' : '' }}" href="{{ path_locale('app_gallery') }}">
                        {{ 'nav.gallery'|trans }}
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path_locale('app_home') }}#avis">
                        {{ 'nav.reviews'|trans }}
                    </a>
                </li>
                <li class="nav-item ms-3">
                    {% set currentLocale = app.request.locale starts with 'de' ? 'de' : 'fr' %}
                    <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'nav.lang_selector_label'|trans }}">
                        <a href="{{ path('app_switch_locale', { locale: 'fr' }) }}?from={{ app.request.pathInfo|url_encode }}"
                           class="btn {{ currentLocale == 'fr' ? 'btn-primary' : 'btn-outline-primary' }}">
                            FR
                        </a>
                        <a href="{{ path('app_switch_locale', { locale: 'de' }) }}?from={{ app.request.pathInfo|url_encode }}"
                           class="btn {{ currentLocale == 'de' ? 'btn-primary' : 'btn-outline-primary' }}">
                            DE
                        </a>
                    </div>
                </li>
            </ul>
        </div>
    </div>
</nav>
<div class="contact-bar py-2">
    <div class="container">
        <div class="row align-items-center justify-content-between">
            <div class="col-auto d-flex flex-wrap gap-4">
                {% if coordinates is defined and coordinates %}
                    {% if coordinates.city is not empty %}
                        <span>📍 {{ coordinates.city }}</span>
                    {% else %}
                        <span>📍 {{ 'nav.city'|trans }}</span>
                    {% endif %}

                    {% set phoneHref = coordinates.phone is not empty
                        ? coordinates.phone|replace({' ': '', '.': '', '-': ''})
                        : null
                    %}
                    {% if phoneHref %}
                        <a href="tel:{{ phoneHref }}">📞 {{ coordinates.phone }}</a>
                    {% else %}
                        <span>📞 {{ 'nav.phone'|trans }}</span>
                    {% endif %}
                {% else %}
                    <span>📍 {{ 'nav.city'|trans }}</span>
                    <span>📞 {{ 'nav.phone'|trans }}</span>
                {% endif %}
                <span>
                    {% if horaires_compact is defined and horaires_compact is not empty %}
                        <a href="{{ path_locale('app_horaires_public') }}" class="">
                            {% include 'components/opening_hours.html.twig' with { rows: horaires_compact, mode: 'compact' } %}
                        </a>
                    {% endif %}
                </span>
            </div>
        </div>
    </div>
</div>
{% include 'components/_breadcrumb.html.twig' %}

