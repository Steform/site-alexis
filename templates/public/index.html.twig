{% extends 'base.html.twig' %}

{% block title %}{{ 'home.title'|trans }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('styles/pages/home.css') }}">
{% endblock %}

{% block body %}
{% include 'partials/_navbar_public.html.twig' %}

{# Messages à date bornée (affichage rouge) #}
{% set currentLocale = app.request.locale starts with 'de' ? 'de' : 'fr' %}
{% set hero_overlay_css = home_content['hero.custom_css']|default('home.hero.custom_css'|trans) %}
{% set hero_text_shadow_color = home_content['hero.text_shadow_color']|default('home.hero.text_shadow_color'|trans) %}
{% for message in messages %}
<div class="alert alert-message alert-dismissible fade show rounded-0 mb-0 text-center" role="alert">
    <strong>
        {% if currentLocale == 'de' and message.contenuDe %}
            {{ message.contenuDe }}
        {% else %}
            {{ message.contenu }}
        {% endif %}
    </strong>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="{{ 'front.common.close'|trans }}"></button>
</div>
{% endfor %}

{# Hero #}
<section class="hero-section">
    {% if hero_photos is not empty %}
        <div class="hero-slider-wrapper">
            <div id="homeHero" class="hero-slider-container">
                <div class="hero-slider">
                    {% for photo in hero_photos %}
                        <div class="hero-slide">
                            <img
                                src="{{ asset(photo.image) }}"
                                alt="{{
                                    app.request.locale starts with 'de'
                                        ? (photo.altDe|default(photo.altFr))
                                        : (photo.altFr|default(photo.altDe))
                                }}"
                                class="hero-slide-img"
                                loading="lazy"
                            >
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}
    <div class="hero-overlay" style="{{ hero_overlay_css }}"></div>
    <div class="container hero-content">
        <div class="row">
            <div class="col-lg-8">
                <div class="mb-4" style="color: {{ home_colors['hero.top_content']|default('#FFFFFF') }}; text-shadow: 0 2px 8px {{ hero_text_shadow_color }};">
                    {{ home_content['hero.top_content']|default('home.hero.top_content'|trans)|raw }}
                </div>
                <a class="btn btn-devis btn-lg rounded-pill" href="{{ path('app_devis') }}" style="color: {{ home_colors['hero.cta']|default('#FFFFFF') }};">{{ home_content['hero.cta']|default('home.hero.cta'|trans) }}</a>
            </div>
        </div>
    </div>
</section>

{# 3 cartes services rapides #}
<section class="py-5 section-soft-blue">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card card-service quick-service quick-service--repair h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="quick-service-head">
                            <img
                                src="{{ asset('images/services/reparation-carrosserie.svg') }}"
                                alt="{{ 'home.quick.card1.title'|trans }}"
                                class="quick-service-icon"
                                width="64"
                                height="64"
                                loading="lazy"
                            >
                            <h5 class="card-title mb-0">{{ 'home.quick.card1.title'|trans }}</h5>
                        </div>

                        <hr class="quick-service-separator">

                        <p class="quick-service-subtext mb-0">
                            {{ 'home.quick.card1.item1'|trans }}, {{ 'home.quick.card1.item2'|trans }}, {{ 'home.quick.card1.item3'|trans }}
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card card-service quick-service quick-service--windshield h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="quick-service-head">
                            <img
                                src="{{ asset('images/services/pare-brise-et-vitrage.svg') }}"
                                alt="{{ 'home.quick.card2.title'|trans }}"
                                class="quick-service-icon"
                                width="64"
                                height="64"
                                loading="lazy"
                            >
                            <h5 class="card-title mb-0">{{ 'home.quick.card2.title'|trans }}</h5>
                        </div>

                        <hr class="quick-service-separator">

                        <p class="quick-service-subtext mb-0">
                            {{ 'home.quick.card2.text'|trans }}
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card card-service quick-service quick-service--maintenance h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="quick-service-head">
                            <img
                                src="{{ asset('images/services/entretien-et-mecanique.svg') }}"
                                alt="{{ 'home.quick.card3.title'|trans }}"
                                class="quick-service-icon"
                                width="64"
                                height="64"
                                loading="lazy"
                            >
                            <h5 class="card-title mb-0">{{ 'home.quick.card3.title'|trans }}</h5>
                        </div>

                        <hr class="quick-service-separator">

                        <p class="quick-service-subtext mb-0">
                            {{ 'home.quick.card3.text'|trans }}
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{# Qui sommes-nous - Identité Alexis Haffner #}
<section id="qui-sommes-nous" class="py-5 section-soft-blue">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-6">
                <h2 class="section-title mb-4" style="color: {{ home_colors['about.title']|default('#212529') }};">{{ home_content['about.title']|default('home.about.title'|trans) }}</h2>
                <p class="fw-bold mb-2" style="color: {{ home_colors['about.lead']|default('#212529') }};">
                    {% if home_content['about.lead'] is defined and home_content['about.lead'] is not empty %}
                        {{ home_content['about.lead'] }}
                    {% else %}
                        {{ 'home.about.lead'|trans }}
                    {% endif %}
                </p>

                {% if home_content['about.body'] is defined and home_content['about.body'] is not empty %}
                    <div class="mb-3" style="color: {{ home_colors['about.body']|default('#6C757D') }};">{{ home_content['about.body']|raw }}</div>
                {% else %}
                    <p class="mb-3" style="color: {{ home_colors['about.body']|default('#6C757D') }};">{{ 'home.about.text'|trans }}</p>
                {% endif %}
                <a class="btn btn-devis rounded-pill" href="{{ path('app_qui_sommes_nous') }}" style="color: {{ home_colors['about.cta']|default('#FFFFFF') }};">{{ home_content['about.cta']|default('home.about.cta'|trans) }}</a>
            </div>
            <div class="col-lg-6">
                {% if about_photos is not empty %}
                    <div class="about-slider-wrapper mx-auto">
                        <div id="about" class="about-slider-container">
                            <div class="about-slider">
                                {% for photo in about_photos %}
                                    <div class="about-slide">
                                        <img
                                            src="{{ asset(photo.image) }}"
                                            alt="{{
                                                app.request.locale starts with 'de'
                                                    ? (photo.altDe|default(photo.altFr))
                                                    : (photo.altFr|default(photo.altDe))
                                            }}"
                                            class="about-slide-img img-fluid rounded shadow"
                                            loading="lazy"
                                        >
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>

{# Nos services (4 cartes avec images) #}
<section id="services" class="py-5 section-soft-blue">
    <div class="container">
        <h2 class="section-title text-center mb-5">{{ 'home.services.title'|trans }}</h2>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="card border-0 overflow-hidden shadow-sm h-100">
                    <img src="https://images.unsplash.com/photo-1551524559-8af4e6624178?w=400" class="card-img-top" alt="Réparation & Peinture" style="height: 200px; object-fit: cover;">
                    <div class="card-img-overlay card-img-overlay-dark d-flex align-items-end">
                        <h5 class="card-title text-white mb-0">{{ 'home.services.card1.title'|trans }}</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card border-0 overflow-hidden shadow-sm h-100">
                    <img src="https://images.unsplash.com/photo-1625047509168-a7026f36de04?w=400" class="card-img-top" alt="Débosselage" style="height: 200px; object-fit: cover;">
                    <div class="card-img-overlay card-img-overlay-dark d-flex align-items-end">
                        <h5 class="card-title text-white mb-0">{{ 'home.services.card2.title'|trans }}</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card border-0 overflow-hidden shadow-sm h-100">
                    <img src="https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?w=400" class="card-img-top" alt="Pare-brise & Vitrages" style="height: 200px; object-fit: cover;">
                    <div class="card-img-overlay card-img-overlay-dark d-flex align-items-end">
                        <h5 class="card-title text-white mb-0">{{ 'home.services.card3.title'|trans }}</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card border-0 overflow-hidden shadow-sm h-100">
                    <img src="https://images.unsplash.com/photo-1549317661-bd32c8ce0db2?w=400" class="card-img-top" alt="Véhicules de courtoisie" style="height: 200px; object-fit: cover;">
                    <div class="card-img-overlay card-img-overlay-dark d-flex align-items-end">
                        <h5 class="card-title text-white mb-0">{{ 'home.services.card4.title'|trans }}</h5>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center mt-4">
            <a class="btn btn-devis rounded-pill" href="{{ path('app_devis') }}">{{ 'home.services.cta'|trans }}</a>
        </div>
    </div>
</section>

{# Avis clients - StuSlider structure per README #}
<section id="avis" class="py-5 testimonial-section">
    <div class="container">
        <h2 class="section-title text-center mb-5">{{ 'home.reviews.title'|trans }}</h2>
        {% if avis|length > 0 %}
        <div class="avis-slider-wrapper mx-auto" style="width: 75%; min-height: 280px;">
        <div class="avis-slider-container">
            <div class="avis-slider">
                {% for a in avis %}
                <div class="avis-slide">
                    <div class="card border-0 shadow-none bg-transparent h-100">
                        <div class="card-body text-center">
                            <div class="avis-quote-icon mb-2">"</div>
                            <p class="card-text fst-italic mb-2">
                                {% if currentLocale == 'de' and a.texteDe %}
                                    {{ a.texteDe }}
                                {% else %}
                                    {{ a.texte }}
                                {% endif %}
                            </p>
                            <p class="avis-author fst-italic mb-0">— {{ a.auteur }}, {{ a.date|date('d/m/Y') }}</p>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        </div>
        {% else %}
        {# Témoignage par défaut (maquette) #}
        <div class="text-center py-5">
            <div class="avis-quote-icon mb-2">"</div>
            <p class="fs-5 fst-italic text-dark mb-2">{{ 'home.reviews.default.text'|trans }}</p>
            <p class="avis-author fst-italic">{{ 'home.reviews.default.author'|trans }}</p>
        </div>
        {% endif %}
    </div>
</section>

{% include 'partials/_footer_public.html.twig' %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script type="module">
    import { StuSlider } from 'https://cdn.jsdelivr.net/npm/stuslider@0.5.3/dist/stuslider.js';

    const heroContainer = document.querySelector('.hero-slider-container');
    if (heroContainer) {
        try {
            const heroSlider = new StuSlider('homeHero', 6000, '100%', '550px', false, false, false, false);
            heroSlider.initialize();
        } catch (error) {
            console.error('Home hero slider init failed:', error);
        }
    }

    const aboutContainer = document.querySelector('.about-slider-container');
    if (aboutContainer) {
        try {
            const aboutSlider = new StuSlider('about', 7000, '100%', '360px', false, false, false, false);
            aboutSlider.initialize();
        } catch (error) {
            console.error('About slider init failed:', error);
        }
    }

    const avisContainer = document.querySelector('.avis-slider-container');
    if (avisContainer) {
        const slider = new StuSlider('avis', 10000, '100%', '280px', false, false, false, false);
        slider.initialize();
    }
</script>
{% endblock %}
