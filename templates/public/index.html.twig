{% extends 'base.html.twig' %}

{% block title %}{{ 'home.title'|trans }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('styles/pages/home.css') }}">
{% endblock %}

{% block body %}
<style>
:root {
  {% for key, c in home_colors|default([]) %}
  --color-{{ key|replace({'.': '-'}) }}: {{ (c.light ?? c)|default('#212529') }};
  {% endfor %}
}
[data-theme="dark"] {
  {% for key, c in home_colors|default([]) %}
  --color-{{ key|replace({'.': '-'}) }}: {{ (c.dark ?? c)|default('#e4e6eb') }};
  {% endfor %}
}
</style>
{% include 'partials/_navbar_public.html.twig' %}

{# Messages à date bornée (affichage rouge) #}
{% set currentLocale = app.request.locale starts with 'de' ? 'de' : 'fr' %}
{% set hero_overlay_css = home_content['hero.custom_css']|default('home.hero.custom_css'|trans) %}
{% set hero_text_shadow_color = home_content['hero.text_shadow_color']|default('home.hero.text_shadow_color'|trans) %}
{% for message in messages %}
<div class="alert alert-message alert-dismissible fade show rounded-0 mb-0 text-center" role="alert">
    <strong>
        {% if currentLocale == 'de' and message.contenuDe %}
            {{ message.contenuDe }}
        {% else %}
            {{ message.contenu }}
        {% endif %}
    </strong>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="{{ 'front.common.close'|trans }}"></button>
</div>
{% endfor %}

{# Hero #}
<section class="hero-section">
    {% if hero_photos is not empty %}
        <div class="hero-slider-wrapper">
            <div id="homeHero" class="hero-slider-container">
                <div class="hero-slider">
                    {% for photo in hero_photos %}
                        <div class="hero-slide">
                            <img
                                src="{{ asset(photo.image) }}"
                                alt="{{
                                    app.request.locale starts with 'de'
                                        ? (photo.altDe|default(photo.altFr))
                                        : (photo.altFr|default(photo.altDe))
                                }}"
                                class="hero-slide-img"
                                loading="lazy"
                            >
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}
    <div class="hero-overlay" style="{{ hero_overlay_css }}"></div>
    <div class="container hero-content">
        <div class="row">
            <div class="col-lg-8">
                <div class="mb-4 hero-text-content" style="color: var(--color-hero-top-content, #FFFFFF); text-shadow: 0 2px 8px {{ hero_text_shadow_color }};">
                    {{ home_content['hero.top_content']|default('home.hero.top_content'|trans)|raw }}
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-outline-light btn-lg rounded-pill" href="{{ path('app_services') }}">{{ 'home.hero.services_link'|trans }}</a>
                </div>
            </div>
        </div>
    </div>
</section>

{# 3 cartes services rapides #}
<section class="py-5 section-soft-blue">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="section-title mb-0" style="color: var(--color-quick-services-title, #212529);">{{ 'home.quick.title'|trans }}</h2>
            <a href="{{ path('app_services') }}" class="btn btn-outline-primary btn-sm">{{ 'home.quick.cta'|trans }}</a>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <a href="{{ path('app_services_show', { slug: 'reparation-carrosserie-peinture' }) }}" class="text-decoration-none">
                    <div class="card card-service quick-service quick-service--repair h-100 border-0 shadow-sm">
                        <div class="card-body p-4">
                            <div class="quick-service-head">
                                <img
                                    src="{{ asset('images/services/reparation-carrosserie.svg') }}"
                                    alt="{{ home_content['quick.card1.title']|default('home.quick.card1.title'|trans) }}"
                                    class="quick-service-icon"
                                    width="64"
                                    height="64"
                                    loading="lazy"
                                >
                                <h5 class="card-title mb-0" style="color: var(--color-quick-card1-title, #0a396a);">{{ home_content['quick.card1.title']|default('home.quick.card1.title'|trans) }}</h5>
                            </div>

                            <hr class="quick-service-separator">

                            <p class="quick-service-subtext mb-0" style="color: var(--color-quick-card1-text, #5c6773);">
                                {{ home_content['quick.card1.text']|default('home.quick.card1.text'|trans) }}
                            </p>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="{{ path('app_services_show', { slug: 'pare-brise-optique' }) }}" class="text-decoration-none">
                    <div class="card card-service quick-service quick-service--windshield h-100 border-0 shadow-sm">
                        <div class="card-body p-4">
                            <div class="quick-service-head">
                                <img
                                    src="{{ asset('images/services/pare-brise-et-vitrage.svg') }}"
                                    alt="{{ home_content['quick.card2.title']|default('home.quick.card2.title'|trans) }}"
                                    class="quick-service-icon"
                                    width="64"
                                    height="64"
                                    loading="lazy"
                                >
                                <h5 class="card-title mb-0" style="color: var(--color-quick-card2-title, #18416d);">{{ home_content['quick.card2.title']|default('home.quick.card2.title'|trans) }}</h5>
                            </div>

                            <hr class="quick-service-separator">

                            <p class="quick-service-subtext mb-0" style="color: var(--color-quick-card2-text, #5c6773);">
                                {{ home_content['quick.card2.text']|default('home.quick.card2.text'|trans) }}
                            </p>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="{{ path('app_services_show', { slug: 'entretien-mecanique' }) }}" class="text-decoration-none">
                    <div class="card card-service quick-service quick-service--maintenance h-100 border-0 shadow-sm">
                        <div class="card-body p-4">
                            <div class="quick-service-head">
                                <img
                                    src="{{ asset('images/services/entretien-et-mecanique.svg') }}"
                                    alt="{{ home_content['quick.card3.title']|default('home.quick.card3.title'|trans) }}"
                                    class="quick-service-icon"
                                    width="64"
                                    height="64"
                                    loading="lazy"
                                >
                                <h5 class="card-title mb-0" style="color: var(--color-quick-card3-title, #09365f);">{{ home_content['quick.card3.title']|default('home.quick.card3.title'|trans) }}</h5>
                            </div>

                            <hr class="quick-service-separator">

                            <p class="quick-service-subtext mb-0" style="color: var(--color-quick-card3-text, #5c6773);">
                                {{ home_content['quick.card3.text']|default('home.quick.card3.text'|trans) }}
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>

{# Qui sommes-nous - Identité Alexis Haffner #}
<section id="qui-sommes-nous" class="py-5 section-soft-blue">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-6">
                <h2 class="section-title mb-4" style="color: var(--color-about-title, #212529);">{{ home_content['about.title']|default('home.about.title'|trans) }}</h2>
                <p class="fw-bold mb-2" style="color: var(--color-about-lead, #212529);">
                    {% if home_content['about.lead'] is defined and home_content['about.lead'] is not empty %}
                        {{ home_content['about.lead'] }}
                    {% else %}
                        {{ 'home.about.lead'|trans }}
                    {% endif %}
                </p>

                {% if home_content['about.body'] is defined and home_content['about.body'] is not empty %}
                    <div class="mb-3" style="color: var(--color-about-body, #6C757D);">{{ home_content['about.body']|raw }}</div>
                {% else %}
                    <p class="mb-3" style="color: var(--color-about-body, #6C757D);">{{ 'home.about.text'|trans }}</p>
                {% endif %}
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-devis rounded-pill" href="{{ path('app_qui_sommes_nous') }}" style="color: var(--color-about-cta, #FFFFFF);">{{ home_content['about.cta']|default('home.about.cta'|trans) }}</a>
                    <a class="btn btn-outline-primary rounded-pill" href="{{ path('app_services') }}">{{ 'home.about.services_link'|trans }}</a>
                </div>
            </div>
            <div class="col-lg-6">
                {% if about_photos is not empty %}
                    <div class="about-slider-wrapper mx-auto">
                        <div id="about" class="about-slider-container">
                            <div class="about-slider">
                                {% for photo in about_photos %}
                                    <div class="about-slide">
                                        <img
                                            src="{{ asset(photo.image) }}"
                                            alt="{{
                                                app.request.locale starts with 'de'
                                                    ? (photo.altDe|default(photo.altFr))
                                                    : (photo.altFr|default(photo.altDe))
                                            }}"
                                            class="about-slide-img img-fluid rounded shadow"
                                            loading="lazy"
                                        >
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>

{# Nos services (4 cartes avec images) #}
<section id="services" class="py-5 section-soft-blue">
    <div class="container">
        <h2 class="section-title text-center mb-5" style="color: var(--color-services-title, #212529);">{{ home_content['services.title']|default('home.services.title'|trans) }}</h2>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="card service-card border-0 overflow-hidden h-100">
                    <a href="{{ path('app_services_show', { slug: 'reparation-carrosserie-peinture' }) }}">
                        <img src="{{ asset('images/services/reparation.webp') }}" class="card-img-top" alt="{{ home_content['services.card1.title']|default('home.services.card1.title'|trans) }}" style="height: 200px; object-fit: cover;" loading="lazy">
                        <div class="card-body p-0 d-flex justify-content-center">
                            <span class="btn btn-service-card" style="color: var(--color-services-card1-title, #fff);">{{ home_content['services.card1.title']|default('home.services.card1.title'|trans) }}</span>
                        </div>
                    </a>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card service-card border-0 overflow-hidden h-100">
                    <a href="{{ path('app_services_show', { slug: 'debosselage' }) }}">
                        <img src="{{ asset('images/services/debosselage.webp') }}" class="card-img-top" alt="{{ home_content['services.card2.title']|default('home.services.card2.title'|trans) }}" style="height: 200px; object-fit: cover;" loading="lazy">
                        <div class="card-body p-0 d-flex justify-content-center">
                            <span class="btn btn-service-card" style="color: var(--color-services-card2-title, #fff);">{{ home_content['services.card2.title']|default('home.services.card2.title'|trans) }}</span>
                        </div>
                    </a>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card service-card border-0 overflow-hidden h-100">
                    <a href="{{ path('app_services_show', { slug: 'pare-brise-optique' }) }}">
                        <img src="{{ asset('images/services/pare-brise.webp') }}" class="card-img-top" alt="{{ home_content['services.card3.title']|default('home.services.card3.title'|trans) }}" style="height: 200px; object-fit: cover;" loading="lazy">
                        <div class="card-body p-0 d-flex justify-content-center">
                            <span class="btn btn-service-card" style="color: var(--color-services-card3-title, #fff);">{{ home_content['services.card3.title']|default('home.services.card3.title'|trans) }}</span>
                        </div>
                    </a>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card service-card border-0 overflow-hidden h-100">
                    <a href="{{ path('app_services_show', { slug: 'vehicule-pret-courtoisie' }) }}">
                        <img src="{{ asset('images/services/vehicule-pret-courtoisie.webp') }}" class="card-img-top" alt="{{ home_content['services.card4.title']|default('home.services.card4.title'|trans) }}" style="height: 200px; object-fit: cover;" loading="lazy">
                        <div class="card-body p-0 d-flex justify-content-center">
                            <span class="btn btn-service-card" style="color: var(--color-services-card4-title, #fff);">{{ home_content['services.card4.title']|default('home.services.card4.title'|trans) }}</span>
                        </div>
                    </a>
                </div>
            </div>
        </div>
        <div class="text-center mt-4">
            <a class="btn btn-devis rounded-pill" href="{{ path('app_services') }}" style="color: var(--color-services-cta, #FFFFFF);">{{ home_content['services.cta']|default('home.services.cta'|trans) }}</a>
        </div>
    </div>
</section>

{# Avis clients - StuSlider structure per README #}
<section id="avis" class="py-5 testimonial-section">
    <div class="container">
        <h2 class="section-title text-center mb-5" style="color: var(--color-reviews-title, #212529);">{{ home_content['reviews.title']|default('home.reviews.title'|trans) }}</h2>
        {% if avis|length > 0 %}
        <div class="avis-slider-wrapper mx-auto" style="width: 75%; min-height: 280px;">
        <div class="avis-slider-container">
            <div class="avis-slider">
                {% for a in avis %}
                <div class="avis-slide">
                    <div class="card border-0 shadow-none bg-transparent h-100">
                        <div class="card-body text-center">
                            <div class="avis-quote-icon mb-2">"</div>
                            <p class="card-text fst-italic mb-2">
                                {% if currentLocale == 'de' and a.texteDe %}
                                    {{ a.texteDe }}
                                {% else %}
                                    {{ a.texte }}
                                {% endif %}
                            </p>
                            <p class="avis-author fst-italic mb-0">— {{ a.auteur }}, {{ a.date|date('d/m/Y') }}</p>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        </div>
        {% else %}
        {# Témoignage par défaut (maquette) #}
        <div class="text-center py-5">
            <div class="avis-quote-icon mb-2">"</div>
            <p class="fs-5 fst-italic mb-2" style="color: var(--color-reviews-default-text, #2c3e50);">{{ home_content['reviews.default.text']|default('home.reviews.default.text'|trans) }}</p>
            <p class="avis-author fst-italic" style="color: var(--color-reviews-default-author, #34495e);">{{ home_content['reviews.default.author']|default('home.reviews.default.author'|trans) }}</p>
        </div>
        {% endif %}
    </div>
</section>

{% include 'partials/_footer_public.html.twig' %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script type="module">
    import { StuSlider } from 'https://cdn.jsdelivr.net/npm/stuslider@0.5.3/dist/stuslider.js';

    const heroContainer = document.querySelector('.hero-slider-container');
    const heroSlidesCount = heroContainer ? heroContainer.querySelectorAll('.hero-slide').length : 0;
    if (heroContainer && heroSlidesCount > 1) {
        try {
            const heroSlider = new StuSlider('homeHero', 6000, '100%', '550px', false, false, false, false);
            heroSlider.initialize();
        } catch (error) {
            console.error('Home hero slider init failed:', error);
        }
    }

    const aboutContainer = document.querySelector('.about-slider-container');
    if (aboutContainer) {
        try {
            const aboutSlider = new StuSlider('about', 7000, '100%', '360px', false, false, false, false);
            aboutSlider.initialize();
        } catch (error) {
            console.error('About slider init failed:', error);
        }
    }

    const avisContainer = document.querySelector('.avis-slider-container');
    if (avisContainer) {
        const slider = new StuSlider('avis', 10000, '100%', '280px', false, false, false, false);
        slider.initialize();
    }
</script>
{% endblock %}
