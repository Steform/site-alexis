{% extends 'base.html.twig' %}

{% block head_hreflang %}
<link rel="alternate" hreflang="fr" href="{{ path_for_locale('app_home', 'fr') }}">
<link rel="alternate" hreflang="de" href="{{ path_for_locale('app_home', 'de') }}">
<link rel="alternate" hreflang="x-default" href="{{ path_for_locale('app_home', 'fr') }}">
{% endblock %}

{% block title %}{{ 'home.title'|trans }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('styles/pages/home.css') }}">
{% endblock %}

{% block body %}
<style>
:root {
  {% for key, c in home_colors|default([]) %}
  --color-{{ key|replace({'.': '-'}) }}: {{ (c.light ?? c)|default('#212529') }};
  {% endfor %}
}
[data-theme="dark"] {
  {% for key, c in home_colors|default([]) %}
  --color-{{ key|replace({'.': '-'}) }}: {{ (c.dark ?? c)|default('#e4e6eb') }};
  {% endfor %}
}
</style>
{% include 'partials/_navbar_public.html.twig' %}

{# Messages à date bornée (affichage rouge) #}
{% set currentLocale = app.request.locale starts with 'de' ? 'de' : 'fr' %}
{% set hero_overlay_css = home_content['hero.custom_css']|default('home.hero.custom_css'|trans) %}
{% set hero_text_shadow_color = home_content['hero.text_shadow_color']|default('home.hero.text_shadow_color'|trans) %}
{% for message in messages %}
<div class="alert alert-message alert-dismissible fade show rounded-0 mb-0 text-center" role="alert">
    <strong>
        {% if currentLocale == 'de' and message.contenuDe %}
            {{ message.contenuDe }}
        {% else %}
            {{ message.contenu }}
        {% endif %}
    </strong>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="{{ 'front.common.close'|trans }}"></button>
</div>
{% endfor %}

{# Hero #}
<section class="hero-section">
    {% if hero_photos is not empty %}
        <div class="hero-slider-wrapper">
            <div id="homeHero" class="hero-slider-container">
                <div class="hero-slider">
                    {% for photo in hero_photos %}
                        <div class="hero-slide">
                            <img
                                src="{{ asset(photo.image) }}"
                                alt="{{
                                    app.request.locale starts with 'de'
                                        ? (photo.altDe|default(photo.altFr))
                                        : (photo.altFr|default(photo.altDe))
                                }}"
                                class="hero-slide-img"
                                loading="lazy"
                            >
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}
    <div class="hero-overlay" style="{{ hero_overlay_css }}"></div>
    <div class="container hero-content">
        <div class="row">
            <div class="col-lg-8">
                <div class="mb-4 hero-text-content" style="color: var(--color-hero-top-content, #FFFFFF); text-shadow: 0 2px 8px {{ hero_text_shadow_color }};">
                    {{ home_content['hero.top_content']|default('home.hero.top_content'|trans)|raw }}
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-devis btn-lg rounded-pill" href="{{ path_locale('app_services') }}" style="color: #FFFFFF;">{{ 'services.list.title'|trans }}</a>
                </div>
            </div>
        </div>
    </div>
</section>

{# Qui sommes-nous - Identité Alexis Haffner #}
<section id="qui-sommes-nous" class="py-5 section-soft-blue">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-6">
                <h2 class="section-title mb-4" style="color: var(--color-about-title, #212529);">{{ home_content['about.title']|default('home.about.title'|trans) }}</h2>
                <p class="fw-bold mb-2" style="color: var(--color-about-lead, #212529);">
                    {% if home_content['about.lead'] is defined and home_content['about.lead'] is not empty %}
                        {{ home_content['about.lead'] }}
                    {% else %}
                        {{ 'home.about.lead'|trans }}
                    {% endif %}
                </p>

                {% if home_content['about.body'] is defined and home_content['about.body'] is not empty %}
                    <div class="mb-3" style="color: var(--color-about-body, #6C757D);">{{ home_content['about.body']|raw }}</div>
                {% else %}
                    <p class="mb-3" style="color: var(--color-about-body, #6C757D);">{{ 'home.about.text'|trans }}</p>
                {% endif %}
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-devis rounded-pill" href="{{ path_locale('app_qui_sommes_nous') }}" style="color: var(--color-about-cta, #FFFFFF);">{{ home_content['about.cta']|default('home.about.cta'|trans) }}</a>
                    <a class="btn btn-devis rounded-pill" href="{{ path_locale('app_services') }}" style="color: #FFFFFF;">{{ 'services.list.title'|trans }}</a>
                </div>
            </div>
            <div class="col-lg-6">
                {% if about_photos is not empty %}
                    <div class="about-slider-wrapper mx-auto">
                        <div id="about" class="about-slider-container">
                            <div class="about-slider">
                                {% for photo in about_photos %}
                                    <div class="about-slide">
                                        <img
                                            src="{{ asset(photo.image) }}"
                                            alt="{{
                                                app.request.locale starts with 'de'
                                                    ? (photo.altDe|default(photo.altFr))
                                                    : (photo.altFr|default(photo.altDe))
                                            }}"
                                            class="about-slide-img img-fluid rounded shadow"
                                            loading="lazy"
                                        >
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>

{# Nos services (5 cartes avec images) #}
<section id="services" class="py-5 section-soft-blue">
    <div class="container">
        {% set servicesList = services|default([]) %}
        {% set s1 = servicesList|filter((s) => s.slug == 'reparation-carrosserie-peinture')|first %}
        {% set s2 = servicesList|filter((s) => s.slug == 'debosselage')|first %}
        {% set s3 = servicesList|filter((s) => s.slug == 'pare-brise-optique')|first %}
        {% set s4 = servicesList|filter((s) => s.slug == 'entretien-mecanique')|first %}
        {% set s5 = servicesList|filter((s) => s.slug == 'vehicule-pret-courtoisie')|first %}
        {% set slugReparation = s1 ? s1.getSlugForLocale(currentLocale) : 'reparation-carrosserie-peinture' %}
        {% set slugDebosselage = s2 ? s2.getSlugForLocale(currentLocale) : 'debosselage' %}
        {% set slugPareBrise = s3 ? s3.getSlugForLocale(currentLocale) : 'pare-brise-optique' %}
        {% set slugEntretien = s4 ? s4.getSlugForLocale(currentLocale) : 'entretien-mecanique' %}
        {% set slugVehicule = s5 ? s5.getSlugForLocale(currentLocale) : 'vehicule-pret-courtoisie' %}
        <h2 class="section-title text-center mb-5" style="color: var(--color-services-title, #212529);">{{ home_content['services.title']|default('home.services.title'|trans) }}</h2>
        <div class="row g-4 justify-content-center">
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card service-card border-0 overflow-hidden h-100">
                    <a href="{{ path_locale('app_services_show', { slug: slugReparation }) }}" title="{{ home_content['services.card1.title']|default('home.services.card1.title'|trans) }}">
                        <img src="{{ asset(home_content['services.card1.image']|default('images/services/reparation-carrosserie-peinture.webp')) }}" class="card-img-top" alt="{{ home_content['services.card1.title']|default('home.services.card1.title'|trans) }}" style="height: 200px; object-fit: cover;" loading="lazy" decoding="async">
                        <div class="card-body p-0 d-flex justify-content-center">
                            <span class="btn btn-service-card" style="color: var(--color-services-card1-title, #fff);">{{ home_content['services.card1.title']|default('home.services.card1.title'|trans) }}</span>
                        </div>
                    </a>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card service-card border-0 overflow-hidden h-100">
                    <a href="{{ path_locale('app_services_show', { slug: slugDebosselage }) }}" title="{{ home_content['services.card2.title']|default('home.services.card2.title'|trans) }}">
                        <img src="{{ asset(home_content['services.card2.image']|default('images/services/debosselage.webp')) }}" class="card-img-top" alt="{{ home_content['services.card2.title']|default('home.services.card2.title'|trans) }}" style="height: 200px; object-fit: cover;" loading="lazy" decoding="async">
                        <div class="card-body p-0 d-flex justify-content-center">
                            <span class="btn btn-service-card" style="color: var(--color-services-card2-title, #fff);">{{ home_content['services.card2.title']|default('home.services.card2.title'|trans) }}</span>
                        </div>
                    </a>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card service-card border-0 overflow-hidden h-100">
                    <a href="{{ path_locale('app_services_show', { slug: slugPareBrise }) }}" title="{{ home_content['services.card3.title']|default('home.services.card3.title'|trans) }}">
                        <img src="{{ asset(home_content['services.card3.image']|default('images/services/pare-brise.webp')) }}" class="card-img-top" alt="{{ home_content['services.card3.title']|default('home.services.card3.title'|trans) }}" style="height: 200px; object-fit: cover;" loading="lazy" decoding="async">
                        <div class="card-body p-0 d-flex justify-content-center">
                            <span class="btn btn-service-card" style="color: var(--color-services-card3-title, #fff);">{{ home_content['services.card3.title']|default('home.services.card3.title'|trans) }}</span>
                        </div>
                    </a>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4 mt-lg-5">
                <div class="card service-card border-0 overflow-hidden h-100">
                    <a href="{{ path_locale('app_services_show', { slug: slugEntretien }) }}" title="{{ home_content['services.card5.title']|default('home.services.card5.title'|trans) }}">
                        <img src="{{ asset(home_content['services.card5.image']|default('images/services/mecanique.webp')) }}" class="card-img-top" alt="{{ home_content['services.card5.title']|default('home.services.card5.title'|trans) }}" style="height: 200px; object-fit: cover;" loading="lazy" decoding="async">
                        <div class="card-body p-0 d-flex justify-content-center">
                            <span class="btn btn-service-card" style="color: var(--color-services-card5-title, #fff);">{{ home_content['services.card5.title']|default('home.services.card5.title'|trans) }}</span>
                        </div>
                    </a>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4 mt-lg-5">
                <div class="card service-card border-0 overflow-hidden h-100">
                    <a href="{{ path_locale('app_services_show', { slug: slugVehicule }) }}" title="{{ home_content['services.card4.title']|default('home.services.card4.title'|trans) }}">
                        <img src="{{ asset(home_content['services.card4.image']|default('images/services/vehicule-pret-courtoisie.webp')) }}" class="card-img-top" alt="{{ home_content['services.card4.title']|default('home.services.card4.title'|trans) }}" style="height: 200px; object-fit: cover;" loading="lazy" decoding="async">
                        <div class="card-body p-0 d-flex justify-content-center">
                            <span class="btn btn-service-card" style="color: var(--color-services-card4-title, #fff);">{{ home_content['services.card4.title']|default('home.services.card4.title'|trans) }}</span>
                        </div>
                    </a>
                </div>
            </div>
        </div>
        <div class="text-center mt-4">
            <a class="btn btn-devis rounded-pill" href="{{ path_locale('app_services') }}" style="color: var(--color-services-cta, #FFFFFF);">{{ 'services.list.title'|trans }}</a>
        </div>
    </div>
</section>

{% include 'components/_avis_slider.html.twig' with {
    avis: avis,
    currentLocale: currentLocale,
    title: home_content['reviews.title']|default('home.reviews.title'|trans),
    default_text: home_content['reviews.default.text']|default('home.reviews.default.text'|trans),
    default_author: home_content['reviews.default.author']|default('home.reviews.default.author'|trans),
    title_style: 'color: var(--color-reviews-title, #212529);',
    default_text_style: 'color: var(--color-reviews-default-text, #2c3e50);',
    default_author_style: 'color: var(--color-reviews-default-author, #34495e);'
} %}

{% include 'partials/_footer_public.html.twig' %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script type="module">
    import { StuSlider } from 'https://cdn.jsdelivr.net/npm/stuslider@0.5.3/dist/stuslider.js';

    const heroContainer = document.querySelector('.hero-slider-container');
    const heroSlidesCount = heroContainer ? heroContainer.querySelectorAll('.hero-slide').length : 0;
    if (heroContainer && heroSlidesCount > 1) {
        try {
            const heroSlider = new StuSlider('hero', 6000, '100%', '550px', false, false, false, false);
            heroSlider.initialize();
        } catch (error) {
            console.error('Home hero slider init failed:', error);
        }
    }

    const aboutContainer = document.querySelector('.about-slider-container');
    if (aboutContainer) {
        try {
            const aboutSlider = new StuSlider('about', 7000, '100%', '360px', false, false, false, false);
            aboutSlider.initialize();
        } catch (error) {
            console.error('About slider init failed:', error);
        }
    }
</script>
{% endblock %}
