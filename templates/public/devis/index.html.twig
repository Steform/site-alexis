{% extends 'base.html.twig' %}

{% block title %}Demander un devis - Carrosserie Lino{% endblock %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block stylesheets %}
{{ parent() }}
<style>
.btn-devis { background: linear-gradient(135deg, #4a90e2, #357abd); color: #fff !important; border: none; font-weight: 600; }
.btn-devis:hover { background: linear-gradient(135deg, #357abd, #2a6ba0); color: #fff !important; }
.section-title { font-size: 1.75rem; font-weight: 700; color: #333; }
[data-theme="dark"] .section-title { color: #e4e6eb; }
</style>
{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="mb-4">Demander un devis</h1>
            <p class="lead text-muted mb-4">Remplissez le formulaire ci-dessous. Nous vous recontacterons rapidement pour étudier votre demande.</p>

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {{ form_start(form, { 'attr': { 'class': 'needs-validation' } }) }}
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            {{ form_row(form.nom) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.email) }}
                        </div>
                        <div class="col-12">
                            {{ form_row(form.telephone) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.vehicule) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.typePrestation) }}
                        </div>
                        <div class="col-12">
                            {{ form_row(form.message) }}
                        </div>
                        <div class="col-12 d-none">
                            {{ form_row(form.website) }}
                        </div>
                    </div>
                    <hr class="my-4">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-devis btn-lg rounded-pill">Envoyer ma demande</button>
                        <a href="{{ path('app_home') }}" class="btn btn-outline-secondary">Retour</a>
                    </div>
                </div>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
