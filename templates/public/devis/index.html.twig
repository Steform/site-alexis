{% extends 'base.html.twig' %}

{% block title %}{{ 'devis.page.title'|trans }}{% endblock %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('styles/pages/devis.css') }}">
{% endblock %}

{% block body %}
{% include 'partials/_navbar_public.html.twig' %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="mb-4">{{ 'devis.title'|trans }}</h1>
            <p class="lead text-muted mb-4">{{ 'devis.lead'|trans }}</p>

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ 'front.common.close'|trans }}"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {{ form_start(form, { 'attr': { 'class': 'needs-validation' } }) }}
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            {{ form_row(form.nom) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.email) }}
                        </div>
                        <div class="col-12">
                            {{ form_row(form.telephone) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.vehicule) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.typePrestation) }}
                        </div>
                        <div class="col-12">
                            {{ form_row(form.message) }}
                        </div>
                        <div class="col-12 d-none">
                            {{ form_row(form.website) }}
                        </div>
                    </div>
                    <hr class="my-4">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-devis btn-lg rounded-pill">{{ 'home.quote.cta'|trans }}</button>
                        <a href="{{ path('app_home') }}" class="btn btn-outline-secondary">{{ 'nav.home'|trans }}</a>
                    </div>
                </div>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% include 'partials/_footer_public.html.twig' %}
{% endblock %}
