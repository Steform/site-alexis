<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: sans-serif; line-height: 1.6; color: #333; }
        .label { font-weight: bold; color: #555; }
        .value { margin-bottom: 1rem; }
        hr { border: none; border-top: 1px solid #ddd; margin: 1.5rem 0; }
    </style>
</head>
<body>
    <h2>Nouvelle demande de devis</h2>
    <p>Une nouvelle demande de devis a été envoyée depuis le site Carrosserie Lino.</p>
    <hr>
    <p><span class="label">Nom :</span><br>{{ devis.nom }}</p>
    <p><span class="label">Email :</span><br>{{ devis.email }}</p>
    <p><span class="label">Téléphone :</span><br>{{ devis.telephone|default('—') }}</p>
    <p><span class="label">Véhicule :</span><br>{{ devis.vehicule }}</p>
    <p><span class="label">Type de prestation :</span><br>
        {% set types = {
            'reparation_carrosserie': 'Réparation carrosserie',
            'peinture': 'Peinture',
            'debosselage': 'Débosselage',
            'pare_brise': 'Pare-brise / Vitrages',
            'entretien': 'Entretien / Mécanique',
            'autre': 'Autre'
        } %}
        {{ types[devis.typePrestation]|default(devis.typePrestation) }}
    </p>
    <p><span class="label">Message :</span><br>{{ devis.message|nl2br }}</p>
    <hr>
    <p style="font-size: 0.9rem; color: #666;">Cet email a été envoyé automatiquement depuis le formulaire de demande de devis du site Carrosserie Lino.</p>
</body>
</html>
