{% extends 'base.html.twig' %}

{% block title %}{{ 'mentions.title'|trans }} - Carrosserie Lino{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.btn-devis { background: linear-gradient(135deg, #4a90e2, #357abd); color: #fff !important; border: none; font-weight: 600; }
.section-title { font-size: 1.75rem; font-weight: 700; color: #333; }
[data-theme="dark"] .section-title { color: #e4e6eb; }
</style>
{% endblock %}

{% block body %}
{% include 'partials/_navbar_public.html.twig' %}
<div class="container py-5">
    <h1 class="section-title mb-4">{{ 'mentions.title'|trans }}</h1>
    <p class="text-muted">{{ 'mentions.placeholder'|trans }}</p>
</div>
{% include 'partials/_footer_public.html.twig' %}
{% endblock %}
