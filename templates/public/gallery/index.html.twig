{% extends 'base.html.twig' %}

{% block title %}{{ 'gallery.title'|trans }} - Carrosserie Lino{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('styles/pages/gallery.css') }}">
{% endblock %}

{% block body %}
{% include 'partials/_navbar_public.html.twig' %}
<div class="container py-5">
    <h1 class="section-title mb-4">{{ 'gallery.title'|trans }}</h1>
    <p class="lead text-muted mb-5">{{ 'gallery.lead'|trans }}</p>

    {% if items|length > 0 %}
    <div class="row g-4">
        {% for item in items %}
        <div class="col-md-6 col-lg-4">
            <div class="card gallery-item border-0 shadow-sm h-100">
                <a href="{{ asset(item.image) }}" target="_blank" class="d-block">
                    <img src="{{ asset(item.image) }}" class="card-img-top gallery-img" alt="{{ item.titre }}">
                </a>
                <div class="card-body">
                    {% set currentLocale = app.request.locale starts with 'de' ? 'de' : 'fr' %}
                    <h5 class="card-title">
                        {% if currentLocale == 'de' and item.titreDe %}
                            {{ item.titreDe }}
                        {% else %}
                            {{ item.titre }}
                        {% endif %}
                    </h5>
                    {% if currentLocale == 'de' and item.descriptionDe %}
                        <p class="card-text text-muted">{{ item.descriptionDe }}</p>
                    {% elseif item.description %}
                        <p class="card-text text-muted">{{ item.description }}</p>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <div class="text-center py-5">
        <p class="text-muted">{{ 'gallery.empty'|trans }}</p>
    </div>
    {% endif %}
</div>
{% include 'partials/_footer_public.html.twig' %}
{% endblock %}
