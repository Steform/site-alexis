{% extends 'base.html.twig' %}

{% block title %}Galerie - Carrosserie Lino{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.btn-devis { background: linear-gradient(135deg, #4a90e2, #357abd); color: #fff !important; border: none; font-weight: 600; }
.section-title { font-size: 1.75rem; font-weight: 700; color: #333; }
[data-theme="dark"] .section-title { color: #e4e6eb; }
.gallery-item { overflow: hidden; }
.gallery-item img { transition: transform 0.3s; }
.gallery-item:hover img { transform: scale(1.05); }
</style>
{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="section-title mb-4">Galerie</h1>
    <p class="lead text-muted mb-5">Découvrez nos réalisations</p>

    {% if items|length > 0 %}
    <div class="row g-4">
        {% for item in items %}
        <div class="col-md-6 col-lg-4">
            <div class="card gallery-item border-0 shadow-sm h-100">
                <a href="{{ asset(item.image) }}" target="_blank" class="d-block">
                    <img src="{{ asset(item.image) }}" class="card-img-top" alt="{{ item.titre }}" style="height: 250px; object-fit: cover;">
                </a>
                <div class="card-body">
                    <h5 class="card-title">{{ item.titre }}</h5>
                    {% if item.description %}
                    <p class="card-text text-muted">{{ item.description }}</p>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <div class="text-center py-5">
        <p class="text-muted">La galerie est vide pour le moment.</p>
    </div>
    {% endif %}
</div>
{% endblock %}
