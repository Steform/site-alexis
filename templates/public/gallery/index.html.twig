{% extends 'base.html.twig' %}

{% block head_hreflang %}
<link rel="alternate" hreflang="fr" href="{{ path_for_locale('app_gallery', 'fr') }}">
<link rel="alternate" hreflang="de" href="{{ path_for_locale('app_gallery', 'de') }}">
<link rel="alternate" hreflang="x-default" href="{{ path_for_locale('app_gallery', 'fr') }}">
{% endblock %}

{% block title %}{{ 'gallery.title'|trans }} - Carrosserie Lino{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('styles/pages/gallery.css') }}">
{% endblock %}

{% block body %}
<style>
:root {
  {% for key, c in gallery_colors|default([]) %}
  --color-gallery-{{ key|replace({'.': '-'}) }}: {{ (c.light ?? c)|default('#212529') }};
  {% endfor %}
}
[data-theme="dark"] {
  {% for key, c in gallery_colors|default([]) %}
  --color-gallery-{{ key|replace({'.': '-'}) }}: {{ (c.dark ?? c)|default('#e4e6eb') }};
  {% endfor %}
}
</style>
{% include 'partials/_navbar_public.html.twig' %}
<div class="container py-5">
    <h1 class="section-title mb-4" style="color: var(--color-gallery-gallery-title, #212529);">{{ gallery_content['gallery.title']|default('gallery.title'|trans) }}</h1>
    <p class="lead mb-5" style="color: var(--color-gallery-gallery-lead, #6C757D);">{{ gallery_content['gallery.lead']|default('gallery.lead'|trans) }}</p>

    {% if items|length > 0 %}
    <div class="row g-4">
        {% for item in items %}
        <div class="col-md-6 col-lg-4">
            <div class="card gallery-item border-0 shadow-sm h-100">
                <a href="{{ asset(item.image) }}" target="_blank" class="d-block">
                    <img src="{{ asset(item.image) }}" class="card-img-top gallery-img" alt="{{ item.titre }}">
                </a>
                <div class="card-body">
                    {% set currentLocale = app.request.locale starts with 'de' ? 'de' : 'fr' %}
                    <h5 class="card-title">
                        {% if currentLocale == 'de' and item.titreDe %}
                            {{ item.titreDe }}
                        {% else %}
                            {{ item.titre }}
                        {% endif %}
                    </h5>
                    {% if currentLocale == 'de' and item.descriptionDe %}
                        <p class="card-text text-muted">{{ item.descriptionDe }}</p>
                    {% elseif item.description %}
                        <p class="card-text text-muted">{{ item.description }}</p>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <div class="text-center py-5">
        <p class="text-muted">{{ 'gallery.empty'|trans }}</p>
    </div>
    {% endif %}
</div>
{% include 'partials/_footer_public.html.twig' %}
{% endblock %}
