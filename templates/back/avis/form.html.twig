{% extends 'back/base.html.twig' %}

{% block title %}{{ avis.id ? 'Modifier' : 'Nouvel' }} avis - Back-office{% endblock %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block back_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">{{ avis.id ? 'Modifier l\'avis' : 'Ajouter un avis' }}</h1>
    <a href="{{ path('app_back_avis_index') }}" class="btn btn-outline-secondary">
        ← Retour à la liste
    </a>
</div>

{{ form_start(form, { 'attr': { 'class': 'needs-validation' } }) }}
<div class="card shadow-sm border-0">
    <div class="card-header bg-primary text-white py-3">
        <h5 class="card-title mb-0">{{ avis.id ? 'Modifier l\'avis client' : 'Nouvel avis client' }}</h5>
    </div>
    <div class="card-body p-4">
        <div class="row g-4">
            <div class="col-12">
                {{ form_row(form.texte, {
                    'row_attr': { 'class': 'mb-0' },
                    'attr': { 'class': 'form-control', 'placeholder': 'Saisir le texte de l\'avis...' }
                }) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.auteur, {
                    'row_attr': { 'class': 'mb-0' },
                    'attr': { 'class': 'form-control', 'placeholder': 'Nom du client' }
                }) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.note, {
                    'row_attr': { 'class': 'mb-0' },
                    'attr': { 'class': 'form-select' }
                }) }}
            </div>
            <div class="col-md-6 col-lg-4">
                {{ form_row(form.date, {
                    'row_attr': { 'class': 'mb-0' },
                    'attr': { 'class': 'form-control' }
                }) }}
            </div>
        </div>
        <hr class="my-4">
        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a href="{{ path('app_back_avis_index') }}" class="btn btn-outline-secondary">Annuler</a>
        </div>
    </div>
</div>
{{ form_end(form) }}
{% endblock %}
