{% extends 'base.html.twig' %}

{% block body %}
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_back_dashboard') }}">{{ 'back.layout.brand'|trans({}, 'back') }}</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarBack" aria-controls="navbarBack" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarBack">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_back_horaires_index') }}">{{ 'back.layout.nav.horaires'|trans({}, 'back') }}</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_back_avis_index') }}">{{ 'back.layout.nav.avis'|trans({}, 'back') }}</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_back_message_index') }}">{{ 'back.layout.nav.messages'|trans({}, 'back') }}</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_back_gallery_index') }}">{{ 'back.layout.nav.gallery'|trans({}, 'back') }}</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path(app.request.locale starts with 'de' ? 'app_back_content_home_de' : 'app_back_content_home_fr') }}">{{ 'back.layout.nav.content'|trans({}, 'back') }}</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_back_about_section_edit') }}">{{ 'back.layout.nav.about'|trans({}, 'back') }}</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_back_coordinates') }}">{{ 'back.layout.nav.coordinates'|trans({}, 'back') }}</a>
                </li>
                {% if is_granted('ROLE_ADMIN') %}
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_back_user_index') }}">{{ 'back.layout.nav.users'|trans({}, 'back') }}</a>
                </li>
                {% endif %}
            </ul>
            {% set currentLocale = app.request.locale starts with 'de' ? 'de' : 'fr' %}
            <div class="d-flex align-items-center me-3">
                <div class="btn-group btn-group-sm me-2" role="group" aria-label="Sélecteur de langue back-office">
                    <a href="{{ path('app_switch_locale', { locale: 'fr' }) }}"
                       class="btn {{ currentLocale == 'fr' ? 'btn-outline-light' : 'btn-outline-secondary' }}">
                        FR
                    </a>
                    <a href="{{ path('app_switch_locale', { locale: 'de' }) }}"
                       class="btn {{ currentLocale == 'de' ? 'btn-outline-light' : 'btn-outline-secondary' }}">
                        DE
                    </a>
                </div>
                <a href="{{ path('app_home') }}" class="btn btn-outline-light btn-sm" aria-label="Retour au site public">
                    <i class="bi bi-house-door"></i>
                </a>
            </div>
            <span class="navbar-text text-light me-3">{{ app.user.nom|default(app.user.email) }}</span>
            <a href="{{ path('app_logout') }}" class="btn btn-outline-light btn-sm">{{ 'back.layout.logout'|trans({}, 'back') }}</a>
        </div>
    </div>
</nav>
<div class="container">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}
    {% block back_content %}{% endblock %}
</div>
{% endblock %}
