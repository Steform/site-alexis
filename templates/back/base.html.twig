{% extends 'base.html.twig' %}

{% block body %}
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_back_dashboard') }}">Back-office</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarBack" aria-controls="navbarBack" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarBack">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_back_horaires_index') }}">Horaires</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_back_avis_index') }}">Avis</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_back_message_index') }}">Messages</a>
                </li>
                {% if is_granted('ROLE_ADMIN') %}
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_back_user_index') }}">Utilisateurs</a>
                </li>
                {% endif %}
            </ul>
            <span class="navbar-text text-light me-3">{{ app.user.nom|default(app.user.email) }}</span>
            <a href="{{ path('app_logout') }}" class="btn btn-outline-light btn-sm">Déconnexion</a>
        </div>
    </div>
</nav>
<div class="container">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}
    {% block back_content %}{% endblock %}
</div>
{% endblock %}
