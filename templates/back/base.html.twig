{% extends 'base.html.twig' %}

{% block body %}
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_back_dashboard') }}">{{ 'back.layout.brand'|trans({}, 'back') }}</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarBack" aria-controls="navbarBack" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarBack">
            <ul class="navbar-nav me-auto">
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="navbarSiteContent" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        {{ 'back.layout.nav.site_content'|trans({}, 'back') }}
                    </a>
                    <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="navbarSiteContent">
                        <li><a class="dropdown-item" href="{{ path('app_back_horaires_index') }}">{{ 'back.layout.nav.horaires'|trans({}, 'back') }}</a></li>
                        <li><a class="dropdown-item" href="{{ path('app_back_message_index') }}">{{ 'back.layout.nav.messages'|trans({}, 'back') }}</a></li>
                        <li><a class="dropdown-item" href="{{ path('app_back_avis_index') }}">{{ 'back.layout.nav.avis'|trans({}, 'back') }}</a></li>
                        <li><a class="dropdown-item" href="{{ path(app.request.locale starts with 'de' ? 'app_back_content_home_de' : 'app_back_content_home_fr') }}">{{ 'back.layout.nav.content'|trans({}, 'back') }}</a></li>
                        <li><a class="dropdown-item" href="{{ path('app_back_coordinates') }}">{{ 'back.layout.nav.coordinates'|trans({}, 'back') }}</a></li>
                    </ul>
                </li>
                {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_PROPRIETAIRE') %}
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="navbarMaintenance" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        {{ 'back.maintenance.title'|trans({}, 'back') }}
                        {% if maintenance_active %}<span class="badge bg-warning text-dark ms-1">ON</span>{% endif %}
                    </a>
                    <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="navbarMaintenance">
                        <li>
                            <form method="post" action="{{ path('app_back_maintenance_toggle') }}" class="px-2 py-1">
                                <input type="hidden" name="_token" value="{{ csrf_token('maintenance_toggle') }}">
                                {% if maintenance_active %}
                                <button type="submit" class="dropdown-item text-warning">{{ 'back.maintenance.disable'|trans({}, 'back') }}</button>
                                {% else %}
                                <button type="submit" class="dropdown-item">{{ 'back.maintenance.enable'|trans({}, 'back') }}</button>
                                {% endif %}
                            </form>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="{{ maintenance_active ? path('app_back_maintenance_bypass') : path('app_home') }}">{{ 'back.maintenance.see_site'|trans({}, 'back') }}</a></li>
                    </ul>
                </li>
                {% endif %}
                {% if is_granted('ROLE_ADMIN') %}
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="navbarAdmin" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        {{ 'back.layout.nav.admin'|trans({}, 'back') }}
                    </a>
                    <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="navbarAdmin">
                        <li><a class="dropdown-item" href="{{ path('app_back_content_history') }}">{{ 'back.layout.nav.history'|trans({}, 'back') }}</a></li>
                        <li><a class="dropdown-item" href="{{ path('app_back_user_index') }}">{{ 'back.layout.nav.users'|trans({}, 'back') }}</a></li>
                        <li><a class="dropdown-item" href="{{ path('app_back_backup_index') }}">{{ 'back.layout.nav.backup'|trans({}, 'back') }}</a></li>
                    </ul>
                </li>
                {% endif %}
            </ul>
            {% set currentLocale = app.request.locale starts with 'de' ? 'de' : 'fr' %}
            <div class="d-flex align-items-center me-3">
                <div class="btn-group btn-group-sm me-2" role="group" aria-label="Sélecteur de langue back-office">
                    <a href="{{ path('app_switch_locale', { locale: 'fr' }) }}"
                       class="btn {{ currentLocale == 'fr' ? 'btn-outline-light' : 'btn-outline-secondary' }}">
                        FR
                    </a>
                    <a href="{{ path('app_switch_locale', { locale: 'de' }) }}"
                       class="btn {{ currentLocale == 'de' ? 'btn-outline-light' : 'btn-outline-secondary' }}">
                        DE
                    </a>
                </div>
                <a href="{{ maintenance_active ? path('app_back_maintenance_bypass') : path('app_home') }}" class="btn btn-outline-light btn-sm" aria-label="{{ maintenance_active ? 'back.maintenance.see_site'|trans({}, 'back') : 'Retour au site public' }}">
                    <i class="bi bi-house-door"></i>
                </a>
            </div>
            <span class="navbar-text text-light me-3">{{ app.user.nom|default(app.user.email) }}</span>
            <a href="{{ path('app_logout') }}" class="btn btn-outline-light btn-sm">{{ 'back.layout.logout'|trans({}, 'back') }}</a>
        </div>
    </div>
</nav>
<div class="container">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}
    {% block back_content %}{% endblock %}
</div>
{% endblock %}
