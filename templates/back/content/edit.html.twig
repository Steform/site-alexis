{% extends 'back/base.html.twig' %}

{% block title %}{{ 'back.content.title'|trans({}, 'back') }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/trix@1.3.1/dist/trix.css">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/trix@1.3.1/dist/trix.js"></script>
    <script>
    function submitDelete(action, token, confirmMsg) {
        if (!confirm(confirmMsg)) return;
        var f = document.createElement('form');
        f.method = 'post';
        f.action = action;
        f.style.display = 'none';
        f.innerHTML = '<input type="hidden" name="_token" value="' + token + '">';
        document.body.appendChild(f);
        f.submit();
    }
    </script>
{% endblock %}

{% block back_content %}
{% set fr_route = page_name == 'home' ? 'app_back_content_home_fr' : (page_name == 'devis' ? 'app_back_content_devis_fr' : (page_name == 'gallery' ? 'app_back_content_gallery_fr' : (page_name == 'mentions_legales' ? 'app_back_content_mentions_legales_fr' : (page_name == 'services' ? 'app_back_content_services_fr' : (page_name starts with 'service_' and current_service ? 'app_back_content_service_detail_fr' : (page_name starts with 'service_' ? 'app_back_content_services_fr' : 'app_back_content_qui_sommes_nous_fr')))))) %}
{% set fr_params = (page_name starts with 'service_' and current_service) ? { slug: current_service.slug } : {} %}
{% set de_route = page_name == 'home' ? 'app_back_content_home_de' : (page_name == 'devis' ? 'app_back_content_devis_de' : (page_name == 'gallery' ? 'app_back_content_gallery_de' : (page_name == 'mentions_legales' ? 'app_back_content_mentions_legales_de' : (page_name == 'services' ? 'app_back_content_services_de' : (page_name starts with 'service_' and current_service ? 'app_back_content_service_detail_de' : (page_name starts with 'service_' ? 'app_back_content_services_de' : 'app_back_content_qui_sommes_nous_de')))))) %}
{% set de_params = (page_name starts with 'service_' and current_service) ? { slug: current_service.slug } : {} %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">{{ 'back.content.heading'|trans({}, 'back') }}</h1>
    <ul class="nav nav-pills mb-0">
        <li class="nav-item">
            <a class="nav-link {{ locale == 'fr' ? 'active' : '' }}" href="{{ path(fr_route, fr_params) }}">
                {{ 'back.content.locale.short.fr'|trans({}, 'back') }}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link {{ locale == 'de' ? 'active' : '' }}" href="{{ path(de_route, de_params) }}">
                {{ 'back.content.locale.short.de'|trans({}, 'back') }}
            </a>
        </li>
    </ul>
</div>

<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link {{ page_name == 'home' ? 'active' : '' }}" href="{{ path(locale == 'fr' ? 'app_back_content_home_fr' : 'app_back_content_home_de') }}">
            {{ 'back.content.tab.home'|trans({}, 'back') }}
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link {{ page_name == 'qui_sommes_nous' ? 'active' : '' }}" href="{{ path(locale == 'fr' ? 'app_back_content_qui_sommes_nous_fr' : 'app_back_content_qui_sommes_nous_de') }}">
            {{ 'back.content.tab.qui'|trans({}, 'back') }}
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link {{ page_name == 'devis' ? 'active' : '' }}" href="{{ path(locale == 'fr' ? 'app_back_content_devis_fr' : 'app_back_content_devis_de') }}">
            {{ 'back.content.tab.devis'|trans({}, 'back') }}
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link {{ page_name == 'gallery' ? 'active' : '' }}" href="{{ path(locale == 'fr' ? 'app_back_content_gallery_fr' : 'app_back_content_gallery_de') }}">
            {{ 'back.content.tab.gallery'|trans({}, 'back') }}
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link {{ (page_name == 'services' or page_name starts with 'service_') ? 'active' : '' }}" href="{{ path(locale == 'fr' ? 'app_back_content_services_fr' : 'app_back_content_services_de') }}">
            {{ 'back.content.tab.services'|trans({}, 'back') }}
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link {{ page_name == 'mentions_legales' ? 'active' : '' }}" href="{{ path(locale == 'fr' ? 'app_back_content_mentions_legales_fr' : 'app_back_content_mentions_legales_de') }}">
            {{ 'back.content.tab.mentions_legales'|trans({}, 'back') }}
        </a>
    </li>
</ul>

{% if page_name == 'services' or page_name starts with 'service_' %}
<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link {{ page_name == 'services' ? 'active' : '' }}" href="{{ path(locale == 'fr' ? 'app_back_content_services_fr' : 'app_back_content_services_de') }}">
            {{ 'back.content.subtab.services_page'|trans({}, 'back') }}
        </a>
    </li>
    {% for service in services|default([]) %}
    <li class="nav-item">
        <a class="nav-link {{ (current_service and current_service.id == service.id) ? 'active' : '' }}" href="{{ path(locale == 'fr' ? 'app_back_content_service_detail_fr' : 'app_back_content_service_detail_de', { slug: service.slug }) }}">
            {{ locale == 'de' ? (service.titreDe|default(service.titre)) : service.titre }}
        </a>
    </li>
    {% endfor %}
</ul>
{% endif %}

<form method="post">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            {% if page_name == 'home' %}
                {% set section_map = {
                    'back.content.section.hero_top': ['hero.top_content', 'hero.text_shadow_color', 'hero.cta'],
                    'back.content.section.hero_photos': ['hero.custom_css'],
                    'back.content.section.about_home': ['about.title', 'about.lead', 'about.body', 'about.cta'],
                    'back.content.section.about_photos': [],
                    'back.content.section.services': ['services.title', 'services.card1.title', 'services.card1.image', 'services.card2.title', 'services.card2.image', 'services.card3.title', 'services.card3.image', 'services.card4.title', 'services.card4.image', 'services.card5.title', 'services.card5.image', 'services.cta'],
                    'back.content.section.reviews': ['reviews.title', 'reviews.default.text', 'reviews.default.author']
                } %}
            {% elseif page_name == 'qui_sommes_nous' %}
                {% set section_map = {
                    'back.content.section.qui_main': ['title', 'alexis.role', 'alexis.lead', 'alexis.text1', 'alexis.text2', 'cta.quote'],
                    'back.content.section.qui_cards': ['card.family.title', 'card.family.text', 'card.expertise.title', 'card.expertise.text', 'card.location.title', 'card.location.text']
                } %}
            {% elseif page_name == 'devis' %}
                {% set section_map = {
                    'back.content.section.devis_main': ['devis.title', 'devis.lead', 'devis.cta'],
                    'back.content.section.devis_types_prestation': [],
                    'back.content.section.devis_types_carburant': []
                } %}
            {% elseif page_name == 'gallery' %}
                {% set section_map = {
                    'back.content.section.gallery_main': ['gallery.title', 'gallery.lead'],
                    'back.content.section.gallery_items': []
                } %}
            {% elseif page_name == 'services' %}
                {% set section_map = {
                    'back.content.section.services_why': [],
                    'back.content.section.services_main': ['why.title', 'list.title', 'cta', 'cta_discover']
                } %}
            {% elseif page_name starts with 'service_' %}
                {% set section_map = {
                    'back.content.section.service_hero': ['teaser'],
                    'back.content.section.service_description': ['description_title', 'description'],
                    'back.content.section.service_advantages': ['advantages_title', 'advantage1', 'advantage2', 'advantage3'],
                    'back.content.section.service_process_title': ['process_title'],
                    'back.content.section.service_process_steps': [],
                    'back.content.section.service_cta': ['cta_lead'],
                    'back.content.section.service_other': ['other_services_title']
                } %}
            {% elseif page_name == 'mentions_legales' %}
                {% set section_map = {
                    'back.content.section.mentions_editor': ['editor'],
                    'back.content.section.mentions_hoster': ['hoster'],
                    'back.content.section.mentions_intellectual': ['intellectual_property'],
                    'back.content.section.mentions_hyperlinks': ['hyperlinks'],
                    'back.content.section.mentions_privacy': ['personal_data'],
                    'back.content.section.mentions_cookies': ['cookies']
                } %}
            {% else %}
                {% set section_map = {} %}
            {% endif %}

            <div class="accordion" id="contentSectionsAccordion_{{ page_name }}_{{ locale }}">
                {% for section_label, section_keys in section_map %}
                    <div class="accordion-item mb-3 border rounded">
                        <h2 class="accordion-header" id="heading_{{ page_name }}_{{ locale }}_{{ loop.index }}">
                            <button
                                class="accordion-button collapsed"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#collapse_{{ page_name }}_{{ locale }}_{{ loop.index }}"
                                aria-expanded="false"
                                aria-controls="collapse_{{ page_name }}_{{ locale }}_{{ loop.index }}"
                            >
                                {{ section_label|trans({}, 'back') }}
                            </button>
                        </h2>
                        <div
                            id="collapse_{{ page_name }}_{{ locale }}_{{ loop.index }}"
                            class="accordion-collapse collapse"
                            aria-labelledby="heading_{{ page_name }}_{{ locale }}_{{ loop.index }}"
                            data-bs-parent="#contentSectionsAccordion_{{ page_name }}_{{ locale }}"
                        >
                            <div class="accordion-body">
                                {% if section_label == 'back.content.section.devis_types_prestation' and page_name == 'devis' %}
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <p class="text-muted mb-0">{{ 'back.content.section.devis_types_prestation.help'|trans({}, 'back') }}</p>
                                        <a href="{{ path('app_back_devis_type_prestation_new') }}" class="btn btn-sm btn-primary">
                                            {{ 'back.devis_type.index.add'|trans({}, 'back') }}
                                        </a>
                                    </div>
                                    <table class="table table-striped">
                                        <thead>
                                            <tr>
                                                <th>{{ 'back.devis_type.index.th.code'|trans({}, 'back') }}</th>
                                                <th>{{ 'back.devis_type.index.th.label_fr'|trans({}, 'back') }}</th>
                                                <th>{{ 'back.devis_type.index.th.label_de'|trans({}, 'back') }}</th>
                                                <th>{{ 'back.devis_type.index.th.ordre'|trans({}, 'back') }}</th>
                                                <th>{{ 'back.devis_type.index.th.actif'|trans({}, 'back') }}</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for t in devis_type_prestations|default([]) %}
                                            <tr>
                                                <td><code>{{ t.code }}</code></td>
                                                <td>{{ t.label }}</td>
                                                <td>{{ t.labelDe|default('—') }}</td>
                                                <td>{{ t.ordre }}</td>
                                                <td>{{ t.actif ? 'Oui' : 'Non' }}</td>
                                                <td>
                                                    <a href="{{ path('app_back_devis_type_prestation_edit', { id: t.id }) }}" class="btn btn-sm btn-outline-primary">
                                                        {{ 'back.avis.index.edit'|trans({}, 'back') }}
                                                    </a>
                                                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="submitDelete('{{ path('app_back_devis_type_prestation_delete', { id: t.id }) }}', '{{ csrf_token('delete' ~ t.id) }}', '{{ 'back.devis_type.index.confirm_delete'|trans({}, 'back') }}')">
                                                        {{ 'back.avis.index.delete'|trans({}, 'back') }}
                                                    </button>
                                                </td>
                                            </tr>
                                            {% else %}
                                            <tr>
                                                <td colspan="6" class="text-muted">
                                                    {{ 'back.devis_type.index.empty'|trans({}, 'back') }}
                                                </td>
                                            </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                {% elseif section_label == 'back.content.section.devis_types_carburant' and page_name == 'devis' %}
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <p class="text-muted mb-0">{{ 'back.content.section.devis_types_carburant.help'|trans({}, 'back') }}</p>
                                        <a href="{{ path('app_back_devis_type_carburant_new') }}" class="btn btn-sm btn-primary">
                                            {{ 'back.devis_type_carburant.index.add'|trans({}, 'back') }}
                                        </a>
                                    </div>
                                    <table class="table table-striped">
                                        <thead>
                                            <tr>
                                                <th>{{ 'back.devis_type_carburant.index.th.code'|trans({}, 'back') }}</th>
                                                <th>{{ 'back.devis_type_carburant.index.th.label_fr'|trans({}, 'back') }}</th>
                                                <th>{{ 'back.devis_type_carburant.index.th.label_de'|trans({}, 'back') }}</th>
                                                <th>{{ 'back.devis_type_carburant.index.th.ordre'|trans({}, 'back') }}</th>
                                                <th>{{ 'back.devis_type_carburant.index.th.actif'|trans({}, 'back') }}</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for t in devis_type_carburants|default([]) %}
                                            <tr>
                                                <td><code>{{ t.code }}</code></td>
                                                <td>{{ t.label }}</td>
                                                <td>{{ t.labelDe|default('—') }}</td>
                                                <td>{{ t.ordre }}</td>
                                                <td>{{ t.actif ? 'Oui' : 'Non' }}</td>
                                                <td>
                                                    <a href="{{ path('app_back_devis_type_carburant_edit', { id: t.id }) }}" class="btn btn-sm btn-outline-primary">
                                                        {{ 'back.avis.index.edit'|trans({}, 'back') }}
                                                    </a>
                                                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="submitDelete('{{ path('app_back_devis_type_carburant_delete', { id: t.id }) }}', '{{ csrf_token('delete' ~ t.id) }}', '{{ 'back.devis_type_carburant.index.confirm_delete'|trans({}, 'back') }}')">
                                                        {{ 'back.avis.index.delete'|trans({}, 'back') }}
                                                    </button>
                                                </td>
                                            </tr>
                                            {% else %}
                                            <tr>
                                                <td colspan="6" class="text-muted">
                                                    {{ 'back.devis_type_carburant.index.empty'|trans({}, 'back') }}
                                                </td>
                                            </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                {% elseif section_label == 'back.content.section.gallery_items' and page_name == 'gallery' %}
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <p class="text-muted mb-0">{{ 'back.content.section.gallery_items.help'|trans({}, 'back') }}</p>
                                        <a href="{{ path('app_back_gallery_new') }}" class="btn btn-sm btn-primary">
                                            {{ 'back.gallery.index.add'|trans({}, 'back') }}
                                        </a>
                                    </div>
                                    <div class="row g-3">
                                        {% for item in gallery_items|default([]) %}
                                            <div class="col-md-6 col-lg-4">
                                                <div class="card h-100 shadow-sm">
                                                    {% if item.image %}
                                                        <img src="{{ asset(item.image) }}" class="card-img-top" alt="{{ item.titre|default('') }}" style="height: 180px; object-fit: cover;">
                                                    {% else %}
                                                        <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 180px;">
                                                            <span class="text-white">{{ 'back.gallery.index.no_image'|trans({}, 'back') }}</span>
                                                        </div>
                                                    {% endif %}
                                                    <div class="card-body">
                                                        <p class="card-text">{{ item.titre|default('—') }}</p>
                                                    </div>
                                                    <div class="card-footer bg-transparent d-flex gap-2">
                                                        <a href="{{ path('app_back_gallery_edit', { id: item.id }) }}" class="btn btn-sm btn-outline-primary">
                                                            {{ 'back.gallery.index.edit'|trans({}, 'back') }}
                                                        </a>
                                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="submitDelete('{{ path('app_back_gallery_delete', { id: item.id }) }}', '{{ csrf_token('delete' ~ item.id) }}', '{{ 'back.gallery.index.confirm_delete'|trans({}, 'back') }}')">
                                                            {{ 'back.gallery.index.delete'|trans({}, 'back') }}
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        {% else %}
                                            <div class="col-12">
                                                <div class="alert alert-info mb-0">
                                                    {{ 'back.gallery.index.empty'|trans({}, 'back') }}
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% elseif section_label == 'back.content.section.about_photos' and page_name == 'home' %}
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <div class="d-flex flex-column">
                                            <p class="text-muted mb-1">{{ 'back.about.photo.image_help'|trans({}, 'back') }}</p>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="badge text-bg-dark">WEBP</span>
                                                <span class="badge text-bg-secondary">Dimensions originales</span>
                                                <span class="badge text-bg-light">{{ (about_photos|default([]))|length }} photo(s)</span>
                                            </div>
                                        </div>
                                        <a href="{{ path('app_back_content_home_photo_new', { locale: locale }) }}" class="btn btn-sm btn-primary">
                                            {{ 'back.about.photos.index.add'|trans({}, 'back') }}
                                        </a>
                                    </div>

                                    {% if (about_photos|default([]))|length > 0 %}
                                        <p class="text-muted small mb-2">{{ 'back.content.slider_reorder_hint'|trans({}, 'back') }}</p>
                                    {% endif %}
                                    <div class="row g-3"
                                        {% if (about_photos|default([]))|length > 0 %}
                                         data-controller="photo-reorder"
                                         data-photo-reorder-url-value="{{ path('app_back_content_home_photos_reorder', { locale: locale }) }}"
                                         data-photo-reorder-csrf-token-value="{{ csrf_token('reorder_home_photos') }}"
                                         data-photo-reorder-success-message-value="{{ 'back.content.slider_reorder_saved'|trans({}, 'back')|e('html_attr') }}"
                                        {% endif %}>
                                        {% for photo in about_photos|default([]) %}
                                            <div class="col-md-6 col-lg-4" data-photo-id="{{ photo.id }}">
                                                <div class="card h-100 shadow-sm">
                                                    {% if photo.image %}
                                                        <img src="{{ asset(photo.image) }}" class="card-img-top" alt="{{ photo.altFr|default('')|default(photo.image) }}" style="height: 220px; object-fit: cover;">
                                                    {% else %}
                                                        <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 220px;">
                                                            <span class="text-white">{{ 'back.gallery.index.no_image'|trans({}, 'back') }}</span>
                                                        </div>
                                                    {% endif %}
                                                    <div class="card-body">
                                                        <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                                                            <button type="button" class="btn btn-sm btn-outline-secondary" data-sortable-handle title="{{ 'back.content.slider_drag_handle'|trans({}, 'back') }}">
                                                                <i class="bi bi-grip-vertical" aria-hidden="true"></i>
                                                            </button>
                                                            <span class="badge text-bg-info">
                                                                {{ 'back.about.photo.position'|trans({}, 'back') }} #{{ photo.position }}
                                                            </span>
                                                            <span class="badge bg-{{ photo.isActive ? 'success' : 'secondary' }}">
                                                                {{ photo.isActive ? 'back.messages.index.status.active'|trans({}, 'back') : 'back.messages.index.status.inactive'|trans({}, 'back') }}
                                                            </span>
                                                        </div>
                                                    </div>
                                                    <div class="card-footer bg-transparent d-flex gap-2">
                                                        <a href="{{ path('app_back_content_home_photo_edit', { locale: locale, id: photo.id }) }}" class="btn btn-sm btn-outline-primary">
                                                            {{ 'back.about.photos.index.edit'|trans({}, 'back') }}
                                                        </a>
                                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="submitDelete('{{ path('app_back_content_home_photo_delete', { locale: locale, id: photo.id }) }}', '{{ csrf_token('delete_home_photo' ~ photo.id) }}', '{{ 'back.about.photos.index.confirm_delete'|trans({}, 'back') }}')">
                                                            {{ 'back.about.photos.index.delete'|trans({}, 'back') }}
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        {% else %}
                                            <div class="col-12">
                                                <div class="alert alert-info mb-0">
                                                    {{ 'back.about.photos.index.empty'|trans({}, 'back') }}
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% elseif section_label == 'back.content.section.services_why' and page_name == 'services' %}
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <p class="text-muted mb-0">{{ 'back.services_why_card.section.help'|trans({}, 'back') }}</p>
                                        <a href="{{ path('app_back_content_services_why_card_new', { locale: locale }) }}" class="btn btn-sm btn-primary">
                                            {{ 'back.services_why_card.index.add'|trans({}, 'back') }}
                                        </a>
                                    </div>
                                    <div class="row g-3">
                                        {% for card in services_why_cards|default([]) %}
                                            <div class="col-md-6 col-lg-4">
                                                <div class="card h-100 shadow-sm">
                                                    <div class="card-body">
                                                        <h6 class="card-title">{{ (locale == 'de' ? card.titleDe : card.titleFr)|default('—') }}</h6>
                                                        <p class="card-text small text-muted">{% set cardText = (locale == 'de' ? card.textDe : card.textFr)|default('') %}{{ cardText|length > 80 ? cardText|slice(0, 77) ~ '...' : cardText }}</p>
                                                        <span class="badge text-bg-info">{{ 'back.services_why_card.position'|trans({}, 'back') }} #{{ card.position }}</span>
                                                    </div>
                                                    <div class="card-footer bg-transparent d-flex gap-2">
                                                        <a href="{{ path('app_back_content_services_why_card_edit', { locale: locale, id: card.id }) }}" class="btn btn-sm btn-outline-primary">
                                                            {{ 'back.avis.index.edit'|trans({}, 'back') }}
                                                        </a>
                                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="submitDelete('{{ path('app_back_content_services_why_card_delete', { locale: locale, id: card.id }) }}', '{{ csrf_token('delete_services_why_card' ~ card.id) }}', '{{ 'back.services_why_card.index.confirm_delete'|trans({}, 'back') }}')">
                                                            {{ 'back.avis.index.delete'|trans({}, 'back') }}
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        {% else %}
                                            <div class="col-12">
                                                <div class="alert alert-info mb-0">
                                                    {{ 'back.services_why_card.index.empty'|trans({}, 'back') }}
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% elseif section_label == 'back.content.section.service_process_steps' and page_name starts with 'service_' and current_service %}
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <p class="text-muted mb-0">{{ 'back.service_process_step.section.help'|trans({}, 'back') }}</p>
                                        <a href="{{ path('app_back_content_service_process_step_new', { locale: locale, slug: current_service.slug }) }}" class="btn btn-sm btn-primary">
                                            {{ 'back.service_process_step.index.add'|trans({}, 'back') }}
                                        </a>
                                    </div>
                                    <div class="row g-3">
                                        {% for step in service_process_steps|default([]) %}
                                            <div class="col-md-6 col-lg-4">
                                                <div class="card h-100 shadow-sm">
                                                    <div class="card-body">
                                                        <h6 class="card-title">{{ (locale == 'de' ? step.labelDe : step.labelFr)|default('—') }}</h6>
                                                        <span class="badge text-bg-info">{{ 'back.service_process_step.position'|trans({}, 'back') }} #{{ step.position }}</span>
                                                    </div>
                                                    <div class="card-footer bg-transparent d-flex gap-2">
                                                        <a href="{{ path('app_back_content_service_process_step_edit', { locale: locale, slug: current_service.slug, id: step.id }) }}" class="btn btn-sm btn-outline-primary">
                                                            {{ 'back.avis.index.edit'|trans({}, 'back') }}
                                                        </a>
                                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="submitDelete('{{ path('app_back_content_service_process_step_delete', { locale: locale, slug: current_service.slug, id: step.id }) }}', '{{ csrf_token('delete_service_process_step' ~ step.id) }}', '{{ 'back.service_process_step.index.confirm_delete'|trans({}, 'back') }}')">
                                                            {{ 'back.avis.index.delete'|trans({}, 'back') }}
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        {% else %}
                                            <div class="col-12">
                                                <div class="alert alert-info mb-0">
                                                    {{ 'back.service_process_step.index.empty'|trans({}, 'back') }}
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {% if section_label == 'back.content.section.hero_photos' and page_name == 'home' %}
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <div class="d-flex flex-column">
                                            <p class="text-muted mb-1">{{ 'back.home_hero.photo.image_help'|trans({}, 'back') }}</p>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="badge text-bg-dark">WEBP</span>
                                                <span class="badge text-bg-secondary">Dimensions originales</span>
                                                <span class="badge text-bg-light">{{ (home_hero_photos|default([]))|length }} photo(s)</span>
                                            </div>
                                        </div>
                                        <a href="{{ path('app_back_content_home_hero_photo_new', { locale: locale }) }}" class="btn btn-sm btn-primary">
                                            {{ 'back.home_hero.photos.index.add'|trans({}, 'back') }}
                                        </a>
                                    </div>

                                    {% if (home_hero_photos|default([]))|length > 0 %}
                                        <p class="text-muted small mb-2">{{ 'back.content.slider_reorder_hint'|trans({}, 'back') }}</p>
                                    {% endif %}
                                    <div class="row g-3"
                                        {% if (home_hero_photos|default([]))|length > 0 %}
                                         data-controller="photo-reorder"
                                         data-photo-reorder-url-value="{{ path('app_back_content_home_hero_photos_reorder', { locale: locale }) }}"
                                         data-photo-reorder-csrf-token-value="{{ csrf_token('reorder_home_hero_photos') }}"
                                         data-photo-reorder-success-message-value="{{ 'back.content.slider_reorder_saved'|trans({}, 'back')|e('html_attr') }}"
                                        {% endif %}>
                                        {% for photo in home_hero_photos|default([]) %}
                                            <div class="col-md-6 col-lg-4" data-photo-id="{{ photo.id }}">
                                                <div class="card h-100 shadow-sm">
                                                    {% if photo.image %}
                                                        <img src="{{ asset(photo.image) }}" class="card-img-top" alt="{{ photo.altFr|default('')|default(photo.image) }}" style="height: 220px; object-fit: cover;">
                                                    {% else %}
                                                        <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 220px;">
                                                            <span class="text-white">{{ 'back.gallery.index.no_image'|trans({}, 'back') }}</span>
                                                        </div>
                                                    {% endif %}
                                                    <div class="card-body">
                                                        <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                                                            <button type="button" class="btn btn-sm btn-outline-secondary" data-sortable-handle title="{{ 'back.content.slider_drag_handle'|trans({}, 'back') }}">
                                                                <i class="bi bi-grip-vertical" aria-hidden="true"></i>
                                                            </button>
                                                            <span class="badge text-bg-info">
                                                                {{ 'back.home_hero.photo.position'|trans({}, 'back') }} #{{ photo.position }}
                                                            </span>
                                                            <span class="badge bg-{{ photo.isActive ? 'success' : 'secondary' }}">
                                                                {{ photo.isActive ? 'back.messages.index.status.active'|trans({}, 'back') : 'back.messages.index.status.inactive'|trans({}, 'back') }}
                                                            </span>
                                                        </div>
                                                    </div>
                                                    <div class="card-footer bg-transparent d-flex gap-2">
                                                        <a href="{{ path('app_back_content_home_hero_photo_edit', { locale: locale, id: photo.id }) }}" class="btn btn-sm btn-outline-primary">
                                                            {{ 'back.home_hero.photos.index.edit'|trans({}, 'back') }}
                                                        </a>
                                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="submitDelete('{{ path('app_back_content_home_hero_photo_delete', { locale: locale, id: photo.id }) }}', '{{ csrf_token('delete_home_hero_photo' ~ photo.id) }}', '{{ 'back.home_hero.photos.index.confirm_delete'|trans({}, 'back') }}')">
                                                            {{ 'back.home_hero.photos.index.delete'|trans({}, 'back') }}
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        {% else %}
                                            <div class="col-12">
                                                <div class="alert alert-info mb-0">
                                                    {{ 'back.home_hero.photos.index.empty'|trans({}, 'back') }}
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}

                                {% if section_label == 'back.content.section.services_main' and page_name == 'services' %}
                                    <div class="mb-4 pb-4 border-bottom">
                                        <p class="text-muted small mb-3">{{ 'back.content.service_teaser_images.help'|trans({}, 'back') }}</p>
                                        <div class="row g-3">
                                            {% for svc in services|default([]) %}
                                                <div class="col-md-6 col-lg-4">
                                                    <div class="card h-100 shadow-sm">
                                                        <div class="card-body">
                                                            <h6 class="card-title">{{ locale == 'de' ? (svc.titreDe|default(svc.titre)) : svc.titre }}</h6>
                                                            <p class="small text-muted mb-2"><code>{{ svc.slug }}</code></p>
                                                            {% if svc.image %}
                                                                <div class="mb-2">
                                                                    <img src="{{ asset(svc.image) }}" alt="" class="img-thumbnail w-100" style="max-height: 140px; object-fit: cover;">
                                                                </div>
                                                                <p class="small text-muted mb-2 text-break"><code>{{ svc.image }}</code></p>
                                                            {% endif %}
                                                            <div class="input-group input-group-sm">
                                                                <input type="file" class="form-control" name="image_file" accept="image/jpeg,image/jpg,image/png,image/webp,image/gif" form="service_teaser_upload_{{ svc.id }}">
                                                                <button type="submit" class="btn btn-outline-primary" form="service_teaser_upload_{{ svc.id }}">{{ 'back.content.service_teaser_image.upload'|trans({}, 'back') }}</button>
                                                            </div>
                                                            <hr class="my-3">
                                                            <p class="small text-muted mb-2">{{ 'back.content.service_detail_hero_image.list_section_help'|trans({}, 'back') }}</p>
                                                            <div class="fw-semibold small mb-2">{{ 'back.content.service_detail_hero_image.title'|trans({}, 'back') }}</div>
                                                            {% if svc.detailHeroImage %}
                                                                <div class="mb-2">
                                                                    <img src="{{ asset(svc.detailHeroImage) }}" alt="" class="img-thumbnail w-100" style="max-height: 140px; object-fit: cover;">
                                                                </div>
                                                                <p class="small text-muted mb-2 text-break"><code>{{ svc.detailHeroImage }}</code></p>
                                                            {% else %}
                                                                <p class="small text-muted mb-2">{{ 'back.content.service_detail_hero_image.fallback_hint'|trans({}, 'back') }}</p>
                                                            {% endif %}
                                                            <div class="input-group input-group-sm">
                                                                <input type="file" class="form-control" name="image_file" accept="image/jpeg,image/jpg,image/png,image/webp,image/gif" form="service_detail_hero_upload_list_{{ svc.id }}">
                                                                <button type="submit" class="btn btn-outline-primary" form="service_detail_hero_upload_list_{{ svc.id }}">{{ 'back.content.service_detail_hero_image.upload'|trans({}, 'back') }}</button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                {% endif %}

                                {% if section_label == 'back.content.section.service_hero' and page_name starts with 'service_' and current_service %}
                                    <div class="mb-4 pb-4 border-bottom">
                                        <p class="text-muted small mb-3">{{ 'back.content.service_detail_hero_image.help'|trans({}, 'back') }}</p>
                                        <div class="card h-100 shadow-sm border-0 bg-light">
                                            <div class="card-body">
                                                <h6 class="card-title">{{ 'back.content.service_detail_hero_image.title'|trans({}, 'back') }}</h6>
                                                <p class="small text-muted mb-2"><code>{{ current_service.slug }}</code></p>
                                                {% if current_service.detailHeroImage %}
                                                    <div class="mb-2">
                                                        <img src="{{ asset(current_service.detailHeroImage) }}" alt="" class="img-thumbnail w-100" style="max-height: 220px; object-fit: cover;">
                                                    </div>
                                                    <p class="small text-muted mb-3 text-break"><code>{{ current_service.detailHeroImage }}</code></p>
                                                {% else %}
                                                    <p class="small text-muted mb-3">{{ 'back.content.service_detail_hero_image.fallback_hint'|trans({}, 'back') }}</p>
                                                {% endif %}
                                                <div class="input-group input-group-sm">
                                                    <input type="file" class="form-control" name="image_file" accept="image/jpeg,image/jpg,image/png,image/webp,image/gif" form="service_detail_hero_upload_{{ current_service.id }}">
                                                    <button type="submit" class="btn btn-outline-primary" form="service_detail_hero_upload_{{ current_service.id }}">{{ 'back.content.service_detail_hero_image.upload'|trans({}, 'back') }}</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}

                                {% for block_key in section_keys %}
                                    {% set config = definitions[block_key]|default(null) %}
                                    {% if config %}
                                        <div class="border rounded p-3 mb-3">
                                            <div class="fw-semibold mb-3">
                                                {{ ('back.content.block.' ~ block_key|replace({'.':'_'}))|trans({}, 'back') }}
                                            </div>
                                            {% if block_key not in ['hero.custom_css', 'hero.text_shadow_color'] and not (block_key starts with 'services.card' and block_key ends with '.image') %}
                                                <div class="row g-2 mb-3">
                                                    <div class="col-md-6">
                                                        <label for="color_{{ block_key|replace({'.':'_'}) }}" class="form-label">
                                                            {{ 'back.content.color.label'|trans({}, 'back') }}
                                                        </label>
                                                        <input
                                                            id="color_{{ block_key|replace({'.':'_'}) }}"
                                                            type="color"
                                                            class="form-control form-control-color"
                                                            name="colors[{{ block_key }}]"
                                                            value="{{ (content_colors[block_key].light ?? content_colors[block_key])|default('#212529') }}"
                                                            title="{{ 'back.content.color.help'|trans({}, 'back') }}"
                                                        >
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label for="color_dark_{{ block_key|replace({'.':'_'}) }}" class="form-label">
                                                            {{ 'back.content.color_dark.label'|trans({}, 'back') }}
                                                        </label>
                                                        <input
                                                            id="color_dark_{{ block_key|replace({'.':'_'}) }}"
                                                            type="color"
                                                            class="form-control form-control-color"
                                                            name="colors_dark[{{ block_key }}]"
                                                            value="{{ (content_colors[block_key].dark ?? content_colors[block_key])|default('#e4e6eb') }}"
                                                            title="{{ 'back.content.color_dark.help'|trans({}, 'back') }}"
                                                        >
                                                    </div>
                                                </div>
                                            {% endif %}

                                            <div class="row g-3">
                                                <div class="col-12">
                                                    <label class="form-label">
                                                        {{ locale == 'fr' ? 'back.content.locale.fr'|trans({}, 'back') : 'back.content.locale.de'|trans({}, 'back') }}
                                                    </label>
                                                    {% if block_key == 'hero.custom_css' %}
                                                        <textarea
                                                            class="form-control font-monospace"
                                                            name="content[{{ block_key }}]"
                                                            rows="4"
                                                            placeholder="background: linear-gradient(90deg, rgba(0,0,0,.45) 0%, rgba(0,0,0,.25) 45%, rgba(0,0,0,.2) 100%);"
                                                        >{{ content_values[block_key]|default('') }}</textarea>
                                                        <div class="form-text">{{ 'back.content.hero_css.help'|trans({}, 'back') }}</div>
                                                    {% elseif block_key == 'hero.text_shadow_color' %}
                                                        <input
                                                            id="content_{{ block_key|replace({'.':'_'}) }}_{{ locale }}"
                                                            type="color"
                                                            class="form-control form-control-color"
                                                            name="content[{{ block_key }}]"
                                                            value="{{ content_values[block_key]|default('#000000') }}"
                                                            title="{{ 'back.content.hero_text_shadow.help'|trans({}, 'back') }}"
                                                        >
                                                        <div class="form-text">{{ 'back.content.hero_text_shadow.help'|trans({}, 'back') }}</div>
                                                    {% elseif config.type == 'rich' %}
                                                        <textarea id="content_{{ block_key|replace({'.':'_'}) }}_{{ locale }}" name="content[{{ block_key }}]" class="d-none">{{ content_values[block_key]|default('') }}</textarea>
                                                        <trix-editor input="content_{{ block_key|replace({'.':'_'}) }}_{{ locale }}"></trix-editor>
                                                    {% elseif block_key starts with 'services.card' and block_key ends with '.image' %}
                                                        {% set card_slot = block_key|replace({'services.card': '', '.image': ''}) %}
                                                        {% if content_values[block_key]|default('') is not empty %}
                                                            <div class="mb-2">
                                                                <img src="{{ asset(content_values[block_key]) }}" alt="" class="img-thumbnail" style="max-height: 160px;">
                                                            </div>
                                                            <p class="small text-muted mb-2"><code>{{ content_values[block_key]|default('') }}</code></p>
                                                        {% endif %}
                                                        <div class="input-group input-group-sm mb-2">
                                                            <input type="file" class="form-control" name="image_file" accept="image/jpeg,image/jpg,image/png,image/webp,image/gif" form="home_service_card_upload_{{ card_slot }}">
                                                            <button type="submit" class="btn btn-outline-primary" form="home_service_card_upload_{{ card_slot }}">{{ 'back.content.home_service_card_image.upload'|trans({}, 'back') }}</button>
                                                        </div>
                                                        <input type="hidden" name="content[{{ block_key }}]" value="{{ content_values[block_key]|default('') }}">
                                                        <div class="form-text">{{ 'back.content.home_service_card_image.help'|trans({}, 'back') }}</div>
                                                    {% else %}
                                                        <input type="text" class="form-control" name="content[{{ block_key }}]" value="{{ content_values[block_key]|default('') }}">
                                                    {% endif %}
                                                </div>
                                            </div>
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <button type="submit" class="btn btn-primary">{{ 'back.content.save'|trans({}, 'back') }}</button>
        </div>
    </div>
</form>
{% if page_name == 'home' %}
    {% for slot in 1..5 %}
        <form id="home_service_card_upload_{{ slot }}" method="post" action="{{ path('app_back_content_home_service_card_image_upload', { locale: locale, slot: slot }) }}" enctype="multipart/form-data" class="d-none" aria-hidden="true" tabindex="-1">
            <input type="hidden" name="_token" value="{{ csrf_token('upload_home_service_card_' ~ slot) }}">
        </form>
    {% endfor %}
{% endif %}
{% if page_name == 'services' %}
    {% for svc in services|default([]) %}
        <form id="service_teaser_upload_{{ svc.id }}" method="post" action="{{ path('app_back_content_service_teaser_image_upload', { locale: locale, id: svc.id }) }}" enctype="multipart/form-data" class="d-none" aria-hidden="true" tabindex="-1">
            <input type="hidden" name="_token" value="{{ csrf_token('upload_service_teaser_image_' ~ svc.id) }}">
        </form>
        <form id="service_detail_hero_upload_list_{{ svc.id }}" method="post" action="{{ path('app_back_content_service_detail_hero_image_upload', { locale: locale, slug: svc.slug }) }}" enctype="multipart/form-data" class="d-none" aria-hidden="true" tabindex="-1">
            <input type="hidden" name="_token" value="{{ csrf_token('upload_service_detail_hero_' ~ svc.id) }}">
            <input type="hidden" name="redirect_target" value="services_list">
        </form>
    {% endfor %}
{% endif %}
{% if page_name starts with 'service_' and current_service %}
    <form id="service_detail_hero_upload_{{ current_service.id }}" method="post" action="{{ path('app_back_content_service_detail_hero_image_upload', { locale: locale, slug: current_service.slug }) }}" enctype="multipart/form-data" class="d-none" aria-hidden="true" tabindex="-1">
        <input type="hidden" name="_token" value="{{ csrf_token('upload_service_detail_hero_' ~ current_service.id) }}">
    </form>
{% endif %}
{% endblock %}

