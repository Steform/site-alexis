{% extends 'back/base.html.twig' %}

{% block title %}{{ 'back.content.history.title'|trans({}, 'back') }}{% endblock %}

{% block back_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">{{ 'back.content.history.heading'|trans({}, 'back') }}</h1>
    <a href="{{ path(app.request.locale starts with 'de' ? 'app_back_content_home_de' : 'app_back_content_home_fr') }}" class="btn btn-outline-secondary">
        {{ 'back.content.history.back_to_content'|trans({}, 'back') }}
    </a>
</div>

<form method="get" class="mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-md-3">
            <label for="filter_page" class="form-label">{{ 'back.content.history.page'|trans({}, 'back') }}</label>
            <select name="page" id="filter_page" class="form-select">
                <option value="">{{ 'back.content.history.filter_all'|trans({}, 'back') }}</option>
                <option value="home" {{ page_filter == 'home' ? 'selected' : '' }}>Accueil</option>
                <option value="qui_sommes_nous" {{ page_filter == 'qui_sommes_nous' ? 'selected' : '' }}>Qui sommes-nous</option>
            </select>
        </div>
        <div class="col-md-3">
            <label for="filter_locale" class="form-label">{{ 'back.content.history.locale'|trans({}, 'back') }}</label>
            <select name="locale" id="filter_locale" class="form-select">
                <option value="">{{ 'back.content.history.filter_all'|trans({}, 'back') }}</option>
                <option value="fr" {{ locale_filter == 'fr' ? 'selected' : '' }}>FR</option>
                <option value="de" {{ locale_filter == 'de' ? 'selected' : '' }}>DE</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">{{ 'back.content.history.filter'|trans({}, 'back') }}</button>
        </div>
    </div>
</form>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        {% if history_entries is empty %}
            <div class="p-4 text-center text-muted">
                {{ 'back.content.history.empty'|trans({}, 'back') }}
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>{{ 'back.content.history.page'|trans({}, 'back') }}</th>
                            <th>{{ 'back.content.history.block'|trans({}, 'back') }}</th>
                            <th>{{ 'back.content.history.locale'|trans({}, 'back') }}</th>
                            <th>{{ 'back.content.history.value'|trans({}, 'back') }}</th>
                            <th>{{ 'back.content.history.color'|trans({}, 'back') }}</th>
                            <th>{{ 'back.content.history.date'|trans({}, 'back') }}</th>
                            <th>{{ 'back.content.history.user'|trans({}, 'back') }}</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for entry in history_entries %}
                            <tr>
                                <td>{{ entry.pageName == 'home' ? 'Accueil' : (entry.pageName == 'qui_sommes_nous' ? 'Qui sommes-nous' : entry.pageName) }}</td>
                                <td>{{ ('back.content.block.' ~ entry.blockKey|replace({'.': '_'}))|trans({}, 'back') }}</td>
                                <td><span class="badge bg-secondary">{{ entry.locale|upper }}</span></td>
                                <td class="text-break" style="max-width: 200px;">{{ entry.value|striptags|slice(0, 80) }}{{ entry.value|length > 80 ? '…' : '' }}</td>
                                <td>
                                    {% if entry.color %}
                                        <span class="d-inline-block rounded" style="width: 1.2rem; height: 1.2rem; background: {{ entry.color }};" title="{{ entry.color }}"></span>
                                        {{ entry.color }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td>{{ entry.createdAt|date('d/m/Y H:i') }}</td>
                                <td>{{ entry.createdBy ? (entry.createdBy.nom|default(entry.createdBy.email)) : '—' }}</td>
                                <td>
                                    <form method="post" action="{{ path('app_back_content_rollback', { id: entry.id }) }}" class="d-inline" onsubmit="return confirm('{{ 'back.content.history.restore_confirm'|trans({}, 'back') }}');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('rollback_content_' ~ entry.id) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-primary">{{ 'back.content.history.restore'|trans({}, 'back') }}</button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
