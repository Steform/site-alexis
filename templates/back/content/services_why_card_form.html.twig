{% extends 'back/base.html.twig' %}

{% block title %}
    {% if card.id %}
        {{ 'back.services_why_card.form.title_edit'|trans({}, 'back') }}
    {% else %}
        {{ 'back.services_why_card.form.title_new'|trans({}, 'back') }}
    {% endif %}
{% endblock %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block back_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">
        {% if card.id %}
            {{ 'back.services_why_card.form.heading_edit'|trans({}, 'back') }}
        {% else %}
            {{ 'back.services_why_card.form.heading_new'|trans({}, 'back') }}
        {% endif %}
    </h1>
    <a href="{{ path(locale == 'de' ? 'app_back_content_services_de' : 'app_back_content_services_fr') }}" class="btn btn-outline-secondary btn-sm">
        {{ 'back.services_why_card.form.back_to_content'|trans({}, 'back') }}
    </a>
</div>

{{ form_start(form) }}
<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <div class="row g-4">
            <div class="col-md-6">
                {{ form_row(form.titleFr) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.titleDe) }}
            </div>
            <div class="col-12">
                {{ form_row(form.textFr) }}
            </div>
            <div class="col-12">
                {{ form_row(form.textDe) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.position) }}
            </div>
        </div>
        <hr class="my-4">
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">{{ 'back.services_why_card.form.save'|trans({}, 'back') }}</button>
            <a href="{{ path(locale == 'de' ? 'app_back_content_services_de' : 'app_back_content_services_fr') }}" class="btn btn-outline-secondary">
                {{ 'back.services_why_card.form.cancel'|trans({}, 'back') }}
            </a>
        </div>
    </div>
</div>
{{ form_end(form) }}
{% endblock %}
