{% extends 'back/base.html.twig' %}

{% block title %}
    {% if photo.id %}
        {{ 'back.content.photos.form.title_edit'|trans({}, 'back') }}
    {% else %}
        {{ 'back.content.photos.form.title_new'|trans({}, 'back') }}
    {% endif %}
{% endblock %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block back_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">
        {% if photo.id %}
            {{ 'back.content.photos.form.heading_edit'|trans({}, 'back') }}
        {% else %}
            {{ 'back.content.photos.form.heading_new'|trans({}, 'back') }}
        {% endif %}
    </h1>
    <a href="{{ path(locale == 'de' ? 'app_back_content_home_de' : 'app_back_content_home_fr') }}" class="btn btn-outline-secondary btn-sm">
        {{ 'back.content.photos.form.back_to_content'|trans({}, 'back') }}
    </a>
</div>

{{ form_start(form, { 'attr': { 'enctype': 'multipart/form-data' } }) }}
<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <div class="row g-4">
            <div class="col-md-6">
                {{ form_row(form.altFr) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.altDe) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.position) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.isActive) }}
            </div>
            <div class="col-12">
                {{ form_row(form.imageFile) }}
                {% if photo.image %}
                    <p class="small text-muted mt-2">
                        {{ 'back.about.photo.current_image'|trans({}, 'back') }}
                    </p>
                    <img src="{{ asset(photo.image) }}" alt="" class="img-thumbnail" style="max-height: 120px;">
                {% endif %}
            </div>
        </div>
        <hr class="my-4">
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">{{ 'back.content.photos.form.save'|trans({}, 'back') }}</button>
            <a href="{{ path(locale == 'de' ? 'app_back_content_home_de' : 'app_back_content_home_fr') }}" class="btn btn-outline-secondary">
                {{ 'back.content.photos.form.cancel'|trans({}, 'back') }}
            </a>
        </div>
    </div>
</div>
{{ form_end(form) }}
{% endblock %}

