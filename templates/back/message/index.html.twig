{% extends 'back/base.html.twig' %}

{% block title %}Messages - Back-office{% endblock %}

{% block back_content %}
<h1 class="mb-4">Messages à date bornée</h1>

<p class="text-muted">Ces messages s'affichent sur le site public uniquement entre la date de début et la date de fin.</p>

<p>
    <a href="{{ path('app_back_message_new') }}" class="btn btn-primary">Ajouter un message</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Contenu</th>
            <th>Début</th>
            <th>Fin</th>
            <th>Statut</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        {% for m in messages %}
        <tr>
            <td>{{ m.contenu|slice(0, 60) }}{% if m.contenu|length > 60 %}…{% endif %}</td>
            <td>{{ m.dateDebut|date('d/m/Y H:i') }}</td>
            <td>{{ m.dateFin|date('d/m/Y H:i') }}</td>
            <td>
                {% if m.isActive() %}
                    <span class="badge bg-success">Actif</span>
                {% else %}
                    <span class="badge bg-secondary">Inactif</span>
                {% endif %}
            </td>
            <td>
                <a href="{{ path('app_back_message_edit', { id: m.id }) }}" class="btn btn-sm btn-outline-primary">Modifier</a>
                <form method="post" action="{{ path('app_back_message_delete', { id: m.id }) }}" class="d-inline" onsubmit="return confirm('Supprimer ce message ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ m.id) }}">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                </form>
            </td>
        </tr>
        {% else %}
        <tr>
            <td colspan="5" class="text-muted">Aucun message.</td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
