{% extends 'back/base.html.twig' %}

{% block title %}{{ 'back.coordinates.title'|trans(domain='back') }}{% endblock %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block back_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">
        {{ 'back.coordinates.heading'|trans(domain='back') }}
    </h1>
</div>

{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label }} mb-3">
            {{ message|trans({}, 'back') }}
        </div>
    {% endfor %}
{% endfor %}

{{ form_start(form, { 'attr': { 'class': 'needs-validation' } }) }}
<div class="card shadow-sm border-0">
    <div class="card-header bg-primary text-white py-3">
        <h5 class="card-title mb-0">
            {{ 'back.coordinates.card_title'|trans(domain='back') }}
        </h5>
        <small class="opacity-75">
            {{ 'back.coordinates.card_subtitle'|trans(domain='back') }}
        </small>
    </div>
    <div class="card-body p-4">
        <div class="row g-4">
            <div class="col-md-6">
                {{ form_row(form.companyName) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.phone) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.email) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.street) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.postalCode) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.city) }}
            </div>
            <div class="col-12">
                {{ form_row(form.googleMapsEmbedUrl) }}
                <small class="form-text text-muted">
                    {{ 'back.coordinates.google_maps_help'|trans(domain='back') }}
                </small>
            </div>
            <div class="col-md-6">
                {{ form_row(form.facebookUrl) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.instagramUrl) }}
            </div>
        </div>
        <hr class="my-4">
        <button type="submit" class="btn btn-primary">
            {{ 'back.coordinates.save'|trans(domain='back') }}
        </button>
    </div>
</div>
{{ form_end(form) }}
{% endblock %}

